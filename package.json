{
  "name": "plyco",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "plyco": "pnpm --filter @plyco/cli exec tsx src/index.ts",
    "dev:api": "pnpm --filter @plyco/shared build && pnpm --filter @plyco/db build && pnpm --filter @plyco/api dev",
    "dev:client": "pnpm --filter @plyco/shared build && pnpm --filter cf-app dev",
    "dev:web": "pnpm --filter @plyco/shared build && pnpm --filter cf-web dev",
    "db:generate": "pnpm --filter @plyco/db prisma:generate",
    "db:migrate": "pnpm --filter @plyco/db exec prisma migrate deploy"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "firebase-tools": "^15.19.1",
    "typescript": "~5.9.3"
  }
}
