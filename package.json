{
  "name": "complyflow",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "plyco": "pnpm --filter @complyflow/api exec tsx src/cli/plyco.ts",
    "dev:api": "pnpm --filter @complyflow/shared build && pnpm --filter @complyflow/db build && pnpm --filter @complyflow/api dev",
    "dev:client": "pnpm --filter @complyflow/shared build && pnpm --filter cf-app dev",
    "db:generate": "pnpm --filter @complyflow/db prisma:generate"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "~5.9.3"
  }
}
