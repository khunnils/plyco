# Fastify
HOST=0.0.0.0
PORT=4100
API_DOCS_ENABLED=true

# Prisma/PostgreSQL.
# Leave unset in apps/api/.env to use the API's in-memory local development store.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/plyco

# Airtable provider catalog.
AIRTABLE_BASE=appXXXXXXXXXXXXXX
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Plyco tool API access.
PLYCO_API_KEY=replace-with-random-api-key
PLYCO_API_URL=http://localhost:4100

# Provider lookup LLM.
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_PROVIDER_LOOKUP_MODEL=gemini-2.5-flash
LANGFUSE_PUBLIC_KEY=pk-lf-XXXXXXXX
LANGFUSE_SECRET_KEY=sk-lf-XXXXXXXX
LANGFUSE_BASE_URL=https://cloud.langfuse.com
SENTRY_DSN=https://public-key@o000000.ingest.us.sentry.io/000000
SENTRY_ENVIRONMENT=development

# Organization website lookup for onboarding.
ORGANIZATION_LOOKUP_MODEL=gemini-flash-latest

# Resend email sending and waitlist contact sync.
RESEND_API_KEY=replace-with-resend-api-key
WAITLIST_RESEND_SEGMENT_ID=f60805b5-c9e7-43a9-b207-5105d522b026
INVITATION_EMAIL_FROM=Plyco <invites@example.com>

# Private Google Cloud Storage bucket for generated PDF documents.
DOCUMENT_PDF_BUCKET=plyco-documents-prod
GCP_PROJECT_ID=plyco-prod

# Google OAuth authentication.
API_PUBLIC_URL=http://localhost:4100
CLIENT_URL=http://localhost:4200
WEB_URL=http://localhost:4300
GOOGLE_OAUTH_CLIENT_ID=google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=google-client-secret
SESSION_KEY=replace-with-at-least-32-random-characters
