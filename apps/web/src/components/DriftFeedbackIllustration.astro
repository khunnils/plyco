---
const quotes = [
	{
		text: "Your Privacy Policy states customer data is retained for 90 days, but your Security Policy references 30 days.",
		className: "rotate-[-2deg] lg:mr-8",
	},
	{
		text: "Your subprocessor list doesn't include an analytics provider, but analytics tracking is enabled across your platform.",
		className: "rotate-[1.5deg] lg:ml-10",
	},
	{
		text: "Your policy states MFA is required for all employees, but your access controls show MFA as optional.",
		className: "rotate-[-1deg] lg:mr-14",
	},
	{
		text: "Your privacy documentation says customer data is hosted in the EU, but several US-based processors are listed in your vendor inventory.",
		className: "rotate-[2deg] lg:ml-6",
	},
];
---

<div class="quote-cloud grid gap-4 text-left" aria-label="Illustrative documentation inconsistencies">
	{
		quotes.map((quote, index) => (
			<article class={`quote-card ${quote.className}`} style={`--quote-delay: ${index * 160}ms;`}>
				<span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-lime-100 font-serif text-[1.35rem] font-black leading-none text-lime-800">“</span>
				<blockquote class="m-0 text-[0.9rem] font-semibold leading-relaxed text-slate-950 md:text-base">“{quote.text}”</blockquote>
			</article>
		))
	}
</div>

<style>
	.quote-card {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1rem;
		align-items: start;
		border: 1px solid rgb(226 232 240);
		border-radius: 1rem;
		background: rgba(255, 255, 255, 0.96);
		padding: 1rem;
		box-shadow: 0 14px 35px rgba(15, 23, 42, 0.08);
		animation: quote-drift 4.8s ease-in-out var(--quote-delay) infinite alternate;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.quote-card:hover {
		border-color: rgb(163 230 53);
		box-shadow: 0 18px 42px rgba(15, 23, 42, 0.12);
	}

	@keyframes quote-drift {
		from {
			translate: 0 0;
		}

		to {
			translate: 0 -0.35rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.quote-card {
			animation: none;
		}
	}
</style>
