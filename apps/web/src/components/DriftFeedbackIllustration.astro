---
const quotes = [
	["Your privacy policy states student submissions are retained for 90 days, but your security policy references a 30-day retention period.", "Fictional customer security reviewer"],
	["Your subprocessor list doesn’t include Mixpanel.", "Fictional procurement lead"],
	["Your security policy mentions MFA, but MFA is marked as optional in your access controls.", "Fictional enterprise buyer"],
];
---

<div class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-4 text-left shadow-[0_24px_70px_rgba(15,23,42,0.1)] sm:p-6" aria-label="Illustrative customer feedback about documentation inconsistencies">
	<div class="flex flex-col items-start justify-between gap-4 px-1 pb-4 sm:flex-row sm:items-center">
		<div><span class="block text-[0.68rem] font-extrabold uppercase tracking-[0.1em] text-slate-500">Customer review feedback</span><strong class="mt-1 block text-xl text-slate-950">Questions you don’t want to receive</strong></div>
		<span class="whitespace-nowrap rounded-full border border-lime-200 bg-lime-50 px-3 py-1.5 text-[0.62rem] font-extrabold text-lime-800">Illustrative examples</span>
	</div>
	<div class="grid gap-3">
		{quotes.map(([quote, role]) => (
			<article class="grid grid-cols-[auto_1fr] gap-4 rounded-2xl border border-slate-200 bg-white p-4 shadow-[0_8px_20px_rgba(15,23,42,0.05)] transition hover:-translate-y-0.5 hover:border-amber-400 motion-reduce:transition-none">
				<span class="grid h-8 w-8 place-items-center rounded-lg bg-lime-100 font-serif text-[1.35rem] font-black text-lime-800">“</span>
				<div><blockquote class="m-0 text-[0.82rem] font-semibold leading-relaxed text-slate-950">“{quote}”</blockquote><p class="mt-2 text-[0.62rem] font-extrabold uppercase tracking-[0.03em] text-slate-500">{role}</p></div>
			</article>
		))}
	</div>
</div>
