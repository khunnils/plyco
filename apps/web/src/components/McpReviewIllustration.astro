---
const toolCalls = [
	"get_security_profile",
	"get_privacy_profile",
	"get_organization_providers",
];

const findings = [
	{
		label: "Needs clarification",
		className: "bg-amber-100 text-amber-800",
		text: "Data retention says “as long as necessary,” but no specific retention schedule is recorded.",
	},
	{
		label: "Inconsistent",
		className: "bg-rose-100 text-rose-800",
		text: "The answer says MFA covers every employee, while the workspace only confirms MFA for production access.",
	},
	{
		label: "Missing detail",
		className: "bg-blue-100 text-blue-800",
		text: "The subprocessor answer lists vendors but does not explain what data each provider handles.",
	},
];
---

<div
	class="overflow-hidden rounded-3xl border border-slate-200 bg-white text-left shadow-[0_28px_80px_rgba(15,23,42,0.12)]"
	role="img"
	aria-label="Claude reviewing an attached security questionnaire using company context from the Plyco MCP server"
>
	<div class="flex items-center gap-3 border-b border-slate-200 bg-slate-50 px-5 py-4">
		<div class="flex gap-1" aria-hidden="true">
			<span class="h-[7px] w-[7px] rounded-full bg-slate-300"></span>
			<span class="h-[7px] w-[7px] rounded-full bg-slate-300"></span>
			<span class="h-[7px] w-[7px] rounded-full bg-slate-300"></span>
		</div>
		<strong class="text-xs text-slate-700">Claude · Questionnaire review</strong>
		<span class="ml-auto hidden items-center gap-1.5 rounded-full border border-lime-200 bg-lime-50 px-2.5 py-1 text-[0.62rem] font-bold text-lime-800 sm:inline-flex">
			<i class="h-1.5 w-1.5 rounded-full bg-lime-500"></i>Plyco connected
		</span>
	</div>

	<div class="space-y-4 p-4 sm:p-6">
		<div class="ml-auto max-w-[88%] rounded-2xl rounded-br-md bg-slate-900 p-4 text-sm leading-6 text-white">
			<div class="mb-3 flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-3 py-2 text-xs text-slate-300">
				<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4 shrink-0" aria-hidden="true">
					<path d="M7 3.75h7l4 4V20.25H7V3.75Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
					<path d="M14 3.75v4h4" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
				</svg>
				<span class="truncate">Acme security questionnaire.xlsx</span>
			</div>
			Review the attached questionnaire against our Plyco workspace. Flag answers that are unsupported, inconsistent, or need more detail.
		</div>

		<div class="mr-auto max-w-[92%] rounded-2xl rounded-bl-md border border-slate-200 bg-slate-50 p-4">
			<p class="text-xs font-bold uppercase tracking-[0.12em] text-slate-500">Claude used Plyco</p>
			<div class="mt-3 flex flex-wrap gap-2">
				{toolCalls.map((tool) => (
					<code class="rounded-md border border-slate-200 bg-white px-2 py-1 text-[0.64rem] font-bold text-slate-600">{tool}()</code>
				))}
			</div>
		</div>

		<div class="rounded-2xl border border-slate-200 bg-white p-4 sm:p-5">
			<div class="flex items-center justify-between gap-3">
				<strong class="text-sm text-slate-950">3 answers need attention</strong>
				<span class="text-[0.65rem] font-bold text-slate-400">Grounded in workspace data</span>
			</div>
			<div class="mt-4 grid gap-3">
				{findings.map((finding) => (
					<div class="rounded-xl border border-slate-200 p-3">
						<span class:list={["inline-flex rounded-full px-2 py-1 text-[0.6rem] font-extrabold uppercase tracking-[0.08em]", finding.className]}>{finding.label}</span>
						<p class="mt-2 text-xs font-medium leading-5 text-slate-700">{finding.text}</p>
					</div>
				))}
			</div>
		</div>
	</div>
</div>
