---
interface Props {
	title: string;
	body: string;
}

const { title, body } = Astro.props;
---

<article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
	<div class="mb-5 flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-sm font-semibold text-slate-700">✓</div>
	<h3 class="heading-feature text-slate-950">{title}</h3>
	<p class="mt-3 text-base leading-7 text-slate-600">{body}</p>
</article>
