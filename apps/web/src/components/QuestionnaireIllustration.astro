---
const rows = [
	["01", "Is data encrypted at rest?", "Yes, using AES-256 encryption.", "Security Policy"],
	["02", "Do you require MFA?", "Required for all production access.", "Access Controls"],
	["03", "List your subprocessors.", "AWS, Stripe, Auth0, Mixpanel.", "Vendor Inventory"],
	["04", "How long is customer data retained?", "90 days after account termination.", "Retention Rules"],
];
---

<div class="overflow-hidden rounded-3xl border border-slate-200 bg-white text-left shadow-[0_28px_80px_rgba(15,23,42,0.12)]" role="img" aria-label="Customer security questionnaire with answers generated from an organized source of truth">
	<div class="grid grid-cols-[auto_1fr] items-center gap-4 border-b border-slate-200 bg-slate-50 px-5 py-4 sm:grid-cols-[auto_1fr_auto]">
		<div class="flex gap-1"><span class="h-[7px] w-[7px] rounded-full bg-slate-300"></span><span class="h-[7px] w-[7px] rounded-full bg-slate-300"></span><span class="h-[7px] w-[7px] rounded-full bg-slate-300"></span></div>
		<strong class="truncate text-[0.72rem] text-slate-700">Enterprise security questionnaire.xlsx</strong>
		<i class="hidden whitespace-nowrap rounded-full bg-lime-100 px-2 py-1 text-[0.58rem] font-extrabold not-italic text-lime-800 sm:block">42 of 48 answered</i>
	</div>
	<div class="hidden grid-cols-[1.1fr_1fr_0.65fr] border-b border-slate-200 bg-slate-100 px-5 py-2.5 text-[0.58rem] font-extrabold uppercase tracking-[0.08em] text-slate-500 sm:grid"><span>Question</span><span>Answer</span><span>Source</span></div>
	{rows.map(([number, question, answer, source], index) => (
		<div class:list={["block border-b border-slate-200 p-4 transition-colors hover:bg-lime-50 motion-reduce:transition-none sm:grid sm:min-h-[5.75rem] sm:grid-cols-[1.1fr_1fr_0.65fr] sm:items-stretch sm:p-0", index === 3 && "bg-lime-50"]}>
			<div class="flex items-center gap-3 py-1 text-xs font-bold leading-snug text-slate-700 sm:min-h-[5.75rem] sm:border-r sm:border-slate-200 sm:px-5 sm:py-4"><b class="text-[0.58rem] text-slate-400">{number}</b><span>{question}</span></div>
			<p class="flex items-center gap-2 py-1 text-[0.72rem] leading-snug text-slate-700 sm:min-h-[5.75rem] sm:border-r sm:border-slate-200 sm:px-5 sm:py-4"><i class="grid h-[1.35rem] w-[1.35rem] shrink-0 place-items-center rounded-full bg-lime-100 text-[0.6rem] font-black not-italic text-lime-800">✓</i>{answer}</p>
			<small class="block py-1 pl-8 text-[0.62rem] font-bold text-slate-500 sm:flex sm:min-h-[5.75rem] sm:items-center sm:px-5 sm:py-4">{source}</small>
		</div>
	))}
	<div class="flex flex-col items-start justify-between gap-4 bg-slate-50 px-5 py-4 sm:flex-row sm:items-center">
		<span class="flex items-center gap-2 text-[0.62rem] font-bold text-slate-500"><i class="h-[7px] w-[7px] rounded-full bg-lime-500 shadow-[0_0_0_4px_rgba(163,230,53,0.18)]"></i>Answers linked to source facts</span>
		<span class="rounded-lg bg-slate-900 px-3 py-2 text-[0.65rem] font-extrabold text-white">Export answers <b class="ml-1 text-lime-300">→</b></span>
	</div>
</div>
