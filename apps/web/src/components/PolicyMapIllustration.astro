---
const policies = [
	{ code: "AC", name: "Access control", position: "md:left-[8%] md:top-[9%] md:-rotate-4" },
	{ code: "IR", name: "Incident response", position: "md:right-[8%] md:top-[9%] md:rotate-4" },
	{ code: "DR", name: "Data retention", position: "md:left-[3%] md:top-[39%] md:rotate-2" },
	{ code: "VM", name: "Vendor management", position: "md:right-[3%] md:top-[39%] md:-rotate-2" },
	{ code: "AU", name: "Acceptable use", position: "md:bottom-[7%] md:left-[10%] md:rotate-3" },
	{ code: "IS", name: "Information security", position: "md:bottom-[7%] md:right-[10%] md:-rotate-3" },
];

const connectors = ["rotate-[213deg]", "rotate-[327deg]", "rotate-180", "rotate-0", "rotate-[147deg]", "rotate-[33deg]"];
---

<div
	class="relative mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-3 sm:grid-cols-2 md:block md:min-h-[620px] md:p-0"
	role="img"
	aria-label="Policy documents connected to one central source of truth"
>
	{connectors.map((rotation) => (
		<div class:list={["absolute left-1/2 top-1/2 z-0 hidden h-0.5 w-[260px] origin-left bg-linear-to-r from-lime-400 via-slate-300 to-transparent md:block", rotation]} aria-hidden="true">
			<span class="absolute -left-1 top-[-3px] h-2 w-2 rounded-full bg-lime-500"></span>
		</div>
	))}

	<div class="relative z-20 col-span-full mx-auto mb-3 w-full max-w-[270px] rounded-3xl border border-lime-400 bg-white p-6 text-left shadow-[0_24px_70px_rgba(54,83,20,0.17)] md:absolute md:left-1/2 md:top-1/2 md:mb-0 md:-translate-x-1/2 md:-translate-y-1/2" aria-hidden="true">
		<div class="mb-4 flex h-12 w-12 items-end justify-center gap-1 rounded-xl bg-lime-200 p-3">
			<span class="h-3 w-1 rounded-full bg-lime-900"></span><span class="h-6 w-1 rounded-full bg-lime-900"></span><span class="h-4 w-1 rounded-full bg-lime-900"></span>
		</div>
		<p class="m-0 text-[0.72rem] font-extrabold uppercase tracking-[0.08em] text-lime-700">Single source of truth</p>
		<strong class="mt-1 block text-[1.35rem] leading-tight text-slate-950">Knowledge graph</strong>
		<div class="mt-5 flex justify-between border-t border-slate-200 pt-3 text-[0.68rem] font-bold text-slate-500">
		</div>
	</div>

	{policies.map((policy) => (
		<div class:list={["relative z-10 grid grid-cols-[2.25rem_1fr] gap-x-3 gap-y-2 rounded-2xl border border-slate-200 bg-white/95 p-4 text-left shadow-[0_18px_50px_rgba(15,23,42,0.1)] md:absolute md:w-[220px]", policy.position]} aria-hidden="true">
			<span class="row-span-2 grid h-11 w-9 place-items-center rounded-lg border border-lime-300 bg-lime-100 text-[0.65rem] font-extrabold text-lime-900">{policy.code}</span>
			<strong class="self-end text-[0.82rem] leading-tight text-slate-950">{policy.name}</strong>
			<span class="h-1 w-[90%] rounded-full bg-slate-200"></span>
			<span class="col-span-full h-1 w-[56%] rounded-full bg-slate-200"></span>
			<span class="col-span-full justify-self-start rounded-full bg-slate-100 px-2 py-1 text-[0.65rem] font-bold text-slate-500">Current</span>
		</div>
	))}
</div>
