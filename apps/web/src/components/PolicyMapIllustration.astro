---
const policies = [
	{ code: "AC", name: "Access control", position: "left-[2%] top-[8%] -rotate-4 md:left-[8%] md:top-[9%]" },
	{ code: "IR", name: "Incident response", position: "right-[2%] top-[8%] rotate-4 md:right-[8%] md:top-[9%]" },
	{ code: "DR", name: "Data retention", position: "left-0 top-[39%] rotate-2 md:left-[3%]" },
	{ code: "VM", name: "Vendor management", position: "right-0 top-[39%] -rotate-2 md:right-[3%]" },
	{ code: "AU", name: "Acceptable use", position: "bottom-[7%] left-[4%] rotate-3 md:left-[10%]" },
	{ code: "IS", name: "Information security", position: "bottom-[7%] right-[4%] -rotate-3 md:right-[10%]" },
];

const connectors = ["rotate-[213deg]", "rotate-[327deg]", "rotate-180", "rotate-0", "rotate-[147deg]", "rotate-[33deg]"];
---

<div
	class="relative mx-auto mt-16 min-h-[380px] max-w-[360px] sm:min-h-[500px] sm:max-w-[560px] md:min-h-[620px] md:max-w-5xl"
	role="img"
	aria-label="Policy documents connected to one central source of truth"
>
	{connectors.map((rotation) => (
		<div class:list={["absolute left-1/2 top-1/2 z-0 h-0.5 w-[112px] origin-left bg-linear-to-r from-lime-400 via-slate-300 to-transparent sm:w-[175px] md:w-[260px]", rotation]} aria-hidden="true">
			<span class="absolute -left-1 top-[-3px] h-2 w-2 rounded-full bg-lime-500"></span>
		</div>
	))}

	<div class="absolute left-1/2 top-1/2 z-20 w-full max-w-[170px] -translate-x-1/2 -translate-y-1/2 rounded-2xl border border-lime-400 bg-white p-4 text-left shadow-[0_24px_70px_rgba(54,83,20,0.17)] sm:max-w-[220px] sm:p-5 md:max-w-[270px] md:rounded-3xl md:p-6" aria-hidden="true">
		<div class="mb-3 flex h-10 w-10 items-end justify-center gap-1 rounded-xl bg-lime-200 p-2.5 md:mb-4 md:h-12 md:w-12 md:p-3">
			<span class="h-3 w-1 rounded-full bg-lime-900"></span><span class="h-6 w-1 rounded-full bg-lime-900"></span><span class="h-4 w-1 rounded-full bg-lime-900"></span>
		</div>
		<p class="m-0 text-[0.55rem] font-extrabold uppercase tracking-[0.08em] text-lime-700 sm:text-[0.64rem] md:text-[0.72rem]">Single source of truth</p>
		<strong class="mt-1 block text-base leading-tight text-slate-950 sm:text-xl md:text-[1.35rem]">Knowledge graph</strong>
		<div class="mt-5 flex justify-between border-t border-slate-200 pt-3 text-[0.68rem] font-bold text-slate-500">
		</div>
	</div>

	{policies.map((policy) => (
		<div class:list={["absolute z-10 grid w-[118px] grid-cols-[1.65rem_1fr] gap-x-2 gap-y-1.5 rounded-xl border border-slate-200 bg-white/95 p-2.5 text-left shadow-[0_18px_50px_rgba(15,23,42,0.1)] sm:w-[150px] sm:grid-cols-[2rem_1fr] sm:p-3 md:w-[220px] md:grid-cols-[2.25rem_1fr] md:gap-x-3 md:gap-y-2 md:rounded-2xl md:p-4", policy.position]} aria-hidden="true">
			<span class="row-span-2 grid h-8 w-7 place-items-center rounded-lg border border-lime-300 bg-lime-100 text-[0.55rem] font-extrabold text-lime-900 sm:h-10 sm:w-8 md:h-11 md:w-9 md:text-[0.65rem]">{policy.code}</span>
			<strong class="self-end text-[0.62rem] leading-tight text-slate-950 sm:text-[0.72rem] md:text-[0.82rem]">{policy.name}</strong>
			<span class="h-1 w-[90%] rounded-full bg-slate-200"></span>
			<span class="col-span-full h-1 w-[56%] rounded-full bg-slate-200"></span>
			<span class="col-span-full justify-self-start rounded-full bg-slate-100 px-2 py-1 text-[0.52rem] font-bold text-slate-500 sm:text-[0.58rem] md:text-[0.65rem]">Current</span>
		</div>
	))}
</div>
