---
import "../styles/global.css";

const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:4000";
const signInUrl = `${apiUrl}/auth/google`;

const inventory = [
	{
		label: "Activities",
		description: "Why your company processes data.",
		items: ["Student assessment processing", "Lead generation", "Account management"],
		accent: "blue",
	},
	{
		label: "Data types",
		description: "The information moving through your products.",
		items: ["Student content", "Account data", "Usage analytics"],
		accent: "teal",
	},
	{
		label: "Services",
		description: "The products and surfaces customers use.",
		items: ["Northstar Platform", "Marketing website", "Mobile app"],
		accent: "amber",
	},
];

const onboardingChecks = [
	"Found privacy policy",
	"Detected services",
	"Identified vendors",
	"Imported data categories",
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Plyco — Build customer trust from structured data</title>
		<meta
			name="description"
			content="Build your startup's trust inventory once. Keep privacy policies, subprocessors, security answers, and customer-facing documents aligned as your product changes."
		/>
		<meta property="og:title" content="Your product changes. Your trust documents should too." />
		<meta
			property="og:description"
			content="Plyco connects services, activities, data, and vendors so startup trust documents stay grounded in reality."
		/>
		<meta property="og:type" content="website" />
	</head>
	<body>
		<header class="site-header">
			<nav class="site-nav" aria-label="Main navigation">
				<a href="#top" class="brand" aria-label="Plyco home">
					<span class="brand-mark" aria-hidden="true">
						<svg viewBox="0 0 32 32" fill="none"><path d="M8 9.5h8.5a6.5 6.5 0 0 1 0 13H12v-4h4.5a2.5 2.5 0 0 0 0-5H8v10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" /></svg>
					</span>
					<span>plyco</span>
				</a>
				<div class="nav-links">
					<a href="#inventory">How it works</a>
					<a href="#documents">Documents</a>
					<a href="#drift">Drift detection</a>
				</div>
				<div class="nav-actions">
					<a class="sign-in" href={signInUrl}>Sign in</a>
					<a class="button button-small" href="#waitlist">Join waitlist</a>
				</div>
			</nav>
		</header>

		<main id="top">
			<section class="hero section-shell">
				<div class="hero-glow hero-glow-one"></div>
				<div class="hero-glow hero-glow-two"></div>
				<div class="hero-copy">
					<p class="eyebrow"><span class="status-dot"></span>Customer trust infrastructure for startups</p>
					<h1>Your product changes.<br /><span>Your trust documents should too.</span></h1>
					<p class="hero-lede">
						Connect what your company does, the data it handles, and the vendors it relies on. Plyco turns that structured truth into customer-ready policies and keeps them current.
					</p>
					<form class="waitlist-form hero-form" novalidate>
						<label class="sr-only" for="hero-email">Work email</label>
						<input id="hero-email" name="email" type="email" required autocomplete="email" placeholder="you@company.com" />
						<input class="honeypot" name="website" type="url" tabindex="-1" autocomplete="off" aria-hidden="true" />
						<button type="submit">Join the waitlist <span aria-hidden="true">→</span></button>
					</form>
					<p class="form-status" role="status" aria-live="polite"></p>
					<p class="hero-note">Built for technical founders preparing for serious customer conversations.</p>
				</div>

				<div class="trust-map" aria-label="Northstar Labs trust inventory connecting services, activities, data, providers, and documents">
					<div class="map-toolbar">
						<div class="map-company"><span class="northstar-mark">N</span><div><strong>Northstar Labs</strong><small>Trust inventory</small></div></div>
						<span class="live-pill"><span></span>All systems aligned</span>
					</div>
					<div class="map-flow">
						<div class="map-stage map-stage-company">
							<p>Service</p><div class="map-node node-blue"><span class="node-icon">01</span><strong>Learning platform</strong><small>app.northstar.dev</small></div>
						</div>
						<span class="map-arrow" aria-hidden="true">→</span>
						<div class="map-stage"><p>Activities</p><div class="map-node"><span class="node-icon">02</span><strong>Student assessment</strong><small>Core processing</small></div></div>
						<span class="map-arrow" aria-hidden="true">→</span>
						<div class="map-stage"><p>Data types</p><div class="map-node"><span class="node-icon">03</span><strong>Student content</strong><small>Personal data</small></div></div>
						<span class="map-arrow" aria-hidden="true">→</span>
						<div class="map-stage"><p>Providers</p><div class="map-node node-teal"><span class="node-icon">04</span><strong>Cloud storage</strong><small>US + EU regions</small></div></div>
					</div>
					<div class="map-documents">
						<div><span class="doc-icon"></span><strong>Privacy Policy</strong><small>Current</small></div>
						<div><span class="doc-icon"></span><strong>Subprocessor List</strong><small>Current</small></div>
						<div><span class="doc-icon"></span><strong>Security Policy</strong><small>Current</small></div>
					</div>
					<div class="map-footer"><span>Structured company data</span><span class="map-line"></span><strong>Automatically generated</strong></div>
				</div>
			</section>

			<section class="problem-section section-shell" id="problem">
				<div class="section-intro">
					<p class="section-number">01 / The problem</p>
					<h2>Most startups manage customer trust manually.</h2>
					<p>Your product lives in code. Your trust story is scattered across files, tabs, and answers written from memory.</p>
				</div>
				<div class="manual-work">
					<div class="manual-card policy-sheet"><span class="file-tab">DOC</span><p>Privacy Policy</p><div class="text-line long"></div><div class="text-line"></div><div class="text-line short"></div><small>Last updated 8 months ago</small></div>
					<div class="manual-card spreadsheet"><span class="file-tab green">XLS</span><p>Vendor list.xlsx</p><div class="sheet-grid"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></div><small>Which version is current?</small></div>
					<div class="manual-card questionnaire"><span class="file-tab amber">Q&A</span><p>Security questionnaire</p><div class="answer-row"><span>Encryption at rest?</span><b>Ask engineering</b></div><div class="answer-row"><span>Subprocessors?</span><b>Check spreadsheet</b></div></div>
					<div class="manual-card soc-card"><span class="file-tab purple">SOC</span><p>SOC 2 answers</p><div class="text-line long"></div><div class="text-line short"></div><small>Copied from last customer</small></div>
					<div class="manual-center"><span>?</span><strong>No shared source of truth</strong></div>
				</div>
			</section>

			<section class="inventory-section" id="inventory">
				<div class="section-shell">
					<div class="section-intro centered">
						<p class="section-number">02 / The foundation</p>
						<h2>Build your trust inventory once.</h2>
						<p>Describe your company in the language of your actual product. Plyco keeps the relationships, not just a pile of disconnected answers.</p>
					</div>
					<div class="inventory-grid">
						{inventory.map((group, index) => (
							<article class={`inventory-card accent-${group.accent}`}>
								<div class="inventory-card-head"><span>0{index + 1}</span><div><h3>{group.label}</h3><p>{group.description}</p></div></div>
								<ul>{group.items.map((item) => <li><span></span>{item}</li>)}</ul>
							</article>
						))}
					</div>
					<div class="inventory-connection"><span></span><p>One connected model of how your company works</p><span></span></div>
				</div>
			</section>

			<section class="vendors-section section-shell">
				<div class="split-copy">
					<div><p class="section-number">03 / Vendor reality</p><h2>Connect vendors to reality.</h2><p>Know exactly who processes what, for which product, and in which region. No more reverse-engineering your architecture during a customer review.</p></div>
					<div class="quote-line">A vendor list says who you use.<br /><strong>Plyco explains why they matter.</strong></div>
				</div>
				<div class="vendor-visual">
					<div class="vendor-service"><small>SERVICE</small><strong>Northstar Platform</strong><span>Production application</span></div>
					<div class="vendor-links" aria-hidden="true"><i></i><i></i><i></i></div>
					<div class="vendor-stack">
						<div><span class="vendor-logo blue-logo">C</span><p><strong>Cloudbase</strong><small>Student content · Account data</small></p><b>US + EU</b></div>
						<div><span class="vendor-logo dark-logo">A</span><p><strong>Authkit</strong><small>Account data · Login events</small></p><b>Global</b></div>
						<div><span class="vendor-logo coral-logo">P</span><p><strong>Productloop</strong><small>Usage analytics</small></p><b>EU</b></div>
					</div>
				</div>
			</section>

			<section class="documents-section" id="documents">
				<div class="section-shell documents-layout">
					<div class="document-stack" aria-label="Automatically generated trust documents">
						<div class="document-page page-back"><span>Security Policy</span></div>
						<div class="document-page page-middle"><span>Subprocessor List</span></div>
						<div class="document-page page-front">
							<div class="document-brand"><span>N</span>Northstar Labs</div><small>PRIVACY POLICY</small><h3>How we handle personal data</h3><div class="doc-rule"></div><p>Northstar Labs processes account data, student content, and usage analytics to provide and improve its services.</p><div class="doc-meta"><span>Generated from 12 connected records</span><b>Current</b></div>
						</div>
					</div>
					<div class="section-intro">
						<p class="section-number">04 / Documents</p>
						<h2>One-click policy generation from structured data.</h2>
						<p>Generate privacy, security, and subprocessor documents from the same inventory you use to answer customers. Every claim stays tied to something real.</p>
						<ul class="feature-checks"><li>Plain-language templates</li><li>Traceable source data</li><li>Regenerate when your company changes</li></ul>
					</div>
				</div>
			</section>

			<section class="drift-section section-shell" id="drift">
				<div class="section-intro centered">
					<p class="section-number">05 / Stay current</p>
					<h2>Detect compliance drift.</h2>
					<p>You move fast. Your documents probably should too.</p>
				</div>
				<div class="drift-board">
					<div class="drift-header"><div><span class="pulse-icon"></span><strong>Changes that affect trust</strong></div><small>2 need review</small></div>
					<div class="notification warning-note"><span class="notification-icon">↗</span><div><strong>New US data region enabled</strong><p>Northstar Platform · Cloudbase hosting</p></div><time>12 min ago</time><button type="button">Review impact</button></div>
					<div class="notification"><span class="notification-icon">+</span><div><strong>Subprocessor list changed</strong><p>Productloop added to Usage Analytics</p></div><time>Yesterday</time><button type="button">Update document</button></div>
					<div class="notification resolved"><span class="notification-icon">✓</span><div><strong>Privacy policy regenerated</strong><p>Published from the latest inventory</p></div><time>May 28</time><span class="resolved-label">Resolved</span></div>
				</div>
			</section>

			<section class="onboarding-section">
				<div class="section-shell onboarding-layout">
					<div class="section-intro">
						<p class="section-number">06 / Fast setup</p>
						<h2>Start with your URL.</h2>
						<p>Plyco reads your public product and policy pages to prepare an editable first draft. You review every detail before it becomes part of your trust inventory.</p>
						<p class="grounded-note">Useful automation, with a human in control.</p>
					</div>
					<div class="onboarding-card">
						<div class="browser-bar"><span></span><span></span><span></span><p>plyco / new organization</p></div>
						<div class="url-entry"><label>Company website</label><div><span>https://</span><strong>northstarlabs.dev</strong><b>Analyze →</b></div></div>
						<div class="scan-progress"><span></span></div>
						<ul>{onboardingChecks.map((item, index) => <li style={`--delay:${index * 0.12}s`}><span>✓</span>{item}<small>{index === 0 ? "/privacy" : index === 1 ? "3 services" : index === 2 ? "7 vendors" : "8 categories"}</small></li>)}</ul>
					</div>
				</div>
			</section>

			<section class="waitlist-section" id="waitlist">
				<div class="waitlist-panel">
					<div><p class="eyebrow light"><span class="status-dot"></span>Private beta</p><h2>Build trust before the questionnaire arrives.</h2><p>Join the waitlist for early access and occasional product updates. No compliance theater. No spam.</p></div>
					<form class="waitlist-form final-form" novalidate>
						<div><label for="waitlist-email">Work email</label><input id="waitlist-email" name="email" type="email" required autocomplete="email" placeholder="founder@company.com" /></div>
						<div><label for="waitlist-blocker">Biggest compliance blocker <span>(optional)</span></label><textarea id="waitlist-blocker" name="blocker" rows="3" placeholder="Security questionnaire, vendor review, privacy policy..."></textarea></div>
						<input class="honeypot" name="website" type="url" tabindex="-1" autocomplete="off" aria-hidden="true" />
						<button type="submit">Join the waitlist <span aria-hidden="true">→</span></button>
						<p class="form-status light-status" role="status" aria-live="polite"></p>
					</form>
				</div>
			</section>
		</main>

		<footer>
			<div class="footer-inner">
				<a href="#top" class="brand"><span class="brand-mark" aria-hidden="true"><svg viewBox="0 0 32 32" fill="none"><path d="M8 9.5h8.5a6.5 6.5 0 0 1 0 13H12v-4h4.5a2.5 2.5 0 0 0 0-5H8v10" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" /></svg></span><span>plyco</span></a>
				<p>Practical trust infrastructure for early-stage startups.</p>
				<nav aria-label="Footer navigation"><a href={signInUrl}>Sign in</a><a href="mailto:hello@plyco.dev">Contact</a><a href="#waitlist">Privacy</a></nav>
			</div>
			<p class="legal-note">Plyco provides readiness guidance and organization tools. It does not provide legal advice, certification, or audit assurance.</p>
		</footer>

		<script is:inline define:vars={{ apiUrl }}>
			const forms = document.querySelectorAll(".waitlist-form");

			for (const form of forms) {
				form.addEventListener("submit", async (event) => {
					event.preventDefault();
					const status = form.parentElement?.querySelector(".form-status") ?? form.querySelector(".form-status");
					const button = form.querySelector("button[type='submit']");
					const data = new FormData(form);
					const email = String(data.get("email") ?? "").trim();

					if (!email || !email.includes("@")) {
						status.textContent = "Enter a valid work email.";
						status.dataset.state = "error";
						return;
					}

					button.disabled = true;
					button.dataset.label = button.textContent;
					button.textContent = "Joining...";
					status.textContent = "";

					try {
						const response = await fetch(`${apiUrl}/waitlist`, {
							method: "POST",
							headers: { "Content-Type": "application/json" },
							body: JSON.stringify({
								email,
								blocker: String(data.get("blocker") ?? "").trim() || undefined,
								website: String(data.get("website") ?? ""),
							}),
						});

						if (!response.ok) throw new Error("Request failed");

						form.reset();
						status.textContent = "You're on the list. We'll be in touch.";
						status.dataset.state = "success";
					} catch {
						status.textContent = "We couldn't save your spot. Please try again.";
						status.dataset.state = "error";
					} finally {
						button.disabled = false;
						button.textContent = button.dataset.label;
					}
				});
			}
		</script>
	</body>
</html>
