---
import "../styles/global.css";

const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:4000";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>plyco — Compliance readiness for early-stage startups</title>
		<meta
			name="description"
			content="A lightweight workspace that helps startups organize policies, vendors, evidence, and security basics before enterprise customers ask for SOC 2 or GDPR readiness."
		/>
		<meta property="og:title" content="Avoid Compliance Debt Early" />
		<meta
			property="og:description"
			content="Lightweight compliance readiness for startups moving toward enterprise customers."
		/>
		<meta property="og:type" content="website" />
	</head>
	<body class="bg-slate-50 text-slate-950 antialiased">
		<header class="absolute inset-x-0 top-0 z-50">
			<nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-5" aria-label="Main navigation">
				<a href="#" class="flex items-center gap-3 text-lg font-bold tracking-tight text-slate-950">
					<span class="flex h-9 w-9 items-center justify-center rounded-full bg-lime-200 text-base font-black text-slate-950">C</span>
					<span>plyco</span>
				</a>
				<div class="hidden items-center gap-9 text-sm font-medium text-slate-700 md:flex">
					<a class="transition hover:text-slate-950" href="#problem">All Pages</a>
					<a class="transition hover:text-slate-950" href="#features">Features</a>
					<a class="transition hover:text-slate-950" href="#early-access">Pricing</a>
					<a class="transition hover:text-slate-950" href="mailto:hello@compliancestarter.com">Contact</a>
				</div>
				<a
					href="#early-access"
					class="inline-flex min-h-12 items-center gap-4 rounded-full bg-neutral-950 py-1.5 pl-6 pr-2 text-sm font-bold text-white shadow-sm transition hover:bg-neutral-800"
				>
					Get Started
					<span class="flex h-9 w-9 items-center justify-center rounded-full bg-lime-200 text-xl leading-none text-neutral-950">→</span>
				</a>
			</nav>
		</header>

		<main>
			<section class="relative overflow-hidden bg-white px-6 pb-16 pt-32 md:pb-20 md:pt-36">
				<div class="absolute inset-0 z-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.06)_1px,transparent_1px)] bg-[size:92px_92px]"></div>
				<div class="absolute inset-x-0 top-0 z-0 h-80 bg-linear-to-b from-white via-white/80 to-transparent"></div>
				<div class="absolute inset-x-0 bottom-0 z-0 h-64 bg-linear-to-t from-slate-50 via-white/90 to-transparent"></div>

				<div class="relative z-10 mx-auto max-w-6xl text-center">
					<div class="mx-auto max-w-4xl">
						<p class="mb-6 inline-flex rounded-full border border-lime-200 bg-lime-100 px-4 py-2 text-sm font-bold text-slate-900">
							Compliance readiness for early-stage startups
						</p>
						<h1 class="heading-hero">
							Stop winging your policy docs
						</h1>
						<p class="mx-auto mt-7 max-w-2xl text-lg leading-8 text-slate-600 md:text-xl">
							A lightweight compliance readiness platform for early-stage startups building toward enterprise customers.
						</p>
						<div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
							<a
								href="#early-access"
								class="inline-flex min-h-14 items-center gap-4 rounded-full bg-neutral-950 py-1.5 pl-7 pr-2 text-base font-bold text-white shadow-sm transition hover:bg-neutral-800"
							>
								Join the waitlist
								<span class="flex h-10 w-10 items-center justify-center rounded-full bg-lime-200 text-2xl leading-none text-neutral-950">→</span>
							</a>
							<a
								href="#features"
								class="inline-flex min-h-14 items-center gap-4 rounded-full border border-slate-200 bg-white py-1.5 pl-7 pr-2 text-base font-bold text-slate-900 shadow-sm transition hover:bg-slate-100"
							>
								See what it helps with
								<span class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-2xl leading-none text-neutral-950">→</span>
							</a>
						</div>
						<p class="mx-auto mt-5 max-w-xl text-sm leading-6 text-slate-500">
							For founders preparing for SOC 2, GDPR readiness, security reviews, and enterprise pilots.
						</p>
					</div>

					<div class="policy-map" role="img" aria-label="Policy documents connected to one central source of truth">
						<div class="policy-map__connector policy-map__connector--top-left" aria-hidden="true"></div>
						<div class="policy-map__connector policy-map__connector--top-right" aria-hidden="true"></div>
						<div class="policy-map__connector policy-map__connector--left" aria-hidden="true"></div>
						<div class="policy-map__connector policy-map__connector--right" aria-hidden="true"></div>
						<div class="policy-map__connector policy-map__connector--bottom-left" aria-hidden="true"></div>
						<div class="policy-map__connector policy-map__connector--bottom-right" aria-hidden="true"></div>

						<div class="policy-document policy-document--top-left" aria-hidden="true">
							<span class="policy-document__icon">AC</span>
							<strong>Access control</strong>
							<span class="policy-document__line policy-document__line--long"></span>
							<span class="policy-document__line"></span>
							<span class="policy-document__status">Current</span>
						</div>
						<div class="policy-document policy-document--top-right" aria-hidden="true">
							<span class="policy-document__icon">IR</span>
							<strong>Incident response</strong>
							<span class="policy-document__line policy-document__line--long"></span>
							<span class="policy-document__line"></span>
							<span class="policy-document__status">Current</span>
						</div>
						<div class="policy-document policy-document--left" aria-hidden="true">
							<span class="policy-document__icon">DR</span>
							<strong>Data retention</strong>
							<span class="policy-document__line policy-document__line--long"></span>
							<span class="policy-document__line"></span>
							<span class="policy-document__status">Current</span>
						</div>
						<div class="policy-document policy-document--right" aria-hidden="true">
							<span class="policy-document__icon">VM</span>
							<strong>Vendor management</strong>
							<span class="policy-document__line policy-document__line--long"></span>
							<span class="policy-document__line"></span>
							<span class="policy-document__status">Current</span>
						</div>
						<div class="policy-document policy-document--bottom-left" aria-hidden="true">
							<span class="policy-document__icon">AU</span>
							<strong>Acceptable use</strong>
							<span class="policy-document__line policy-document__line--long"></span>
							<span class="policy-document__line"></span>
							<span class="policy-document__status">Current</span>
						</div>
						<div class="policy-document policy-document--bottom-right" aria-hidden="true">
							<span class="policy-document__icon">IS</span>
							<strong>Information security</strong>
							<span class="policy-document__line policy-document__line--long"></span>
							<span class="policy-document__line"></span>
							<span class="policy-document__status">Current</span>
						</div>

						<div class="policy-source" aria-hidden="true">
							<div class="policy-source__mark">
								<span></span><span></span><span></span>
							</div>
							<p>Single source of truth</p>
							<strong>Policies stay aligned</strong>
							<div class="policy-source__meta">
								<span><i></i> 6 policies</span>
								<span>Synced now</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="problem" class="border-y border-slate-200 bg-white px-6 py-14 md:py-24">
				<div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-16">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Model the foundations</p>
						<h2 class="heading-section mt-4">Model the facts. We’ll handle the documents.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p class="font-semibold text-slate-950">Most policy tools start with templates.</p>
							<p class="font-semibold text-slate-950">We start with your business.</p>
							<p>
								Define the services you offer, the data you collect, the activities you perform, and the vendors you rely on. Claire turns that information into structured documentation that stays consistent across your entire trust stack.
							</p>
							<p>No more updating the same information in five different places.</p>
						</div>
						<ul class="mt-8 grid gap-3 text-base font-medium text-slate-700">
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Define processing activities once</span></li>
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Track data types and retention policies</span></li>
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Maintain a vendor and subprocessor inventory</span></li>
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Map services to the data they actually use</span></li>
						</ul>
					</div>

					<div class="foundation-flow" role="img" aria-label="Activities flow into data types, vendors, and policies">
						<div class="foundation-flow__stage foundation-flow__stage--activities">
							<span class="foundation-flow__number">01</span>
							<div class="foundation-flow__icon"><i></i><i></i><i></i></div>
							<strong>Activities</strong>
							<small>What your business does</small>
							<div class="foundation-flow__tags"><span>Support</span><span>Analytics</span></div>
						</div>
						<div class="foundation-flow__connector" aria-hidden="true"><span></span></div>
						<div class="foundation-flow__stage foundation-flow__stage--data">
							<span class="foundation-flow__number">02</span>
							<div class="foundation-flow__icon foundation-flow__icon--data"><i></i><i></i><i></i></div>
							<strong>Data Types</strong>
							<small>What each activity uses</small>
							<div class="foundation-flow__tags"><span>Account</span><span>Usage</span></div>
						</div>
						<div class="foundation-flow__connector" aria-hidden="true"><span></span></div>
						<div class="foundation-flow__stage foundation-flow__stage--vendors">
							<span class="foundation-flow__number">03</span>
							<div class="foundation-flow__icon foundation-flow__icon--vendors"><i></i><i></i><i></i></div>
							<strong>Vendors</strong>
							<small>Who processes the data</small>
							<div class="foundation-flow__tags"><span>Hosting</span><span>Auth</span></div>
						</div>
						<div class="foundation-flow__connector" aria-hidden="true"><span></span></div>
						<div class="foundation-flow__stage foundation-flow__stage--policies">
							<span class="foundation-flow__number">04</span>
							<div class="foundation-flow__icon foundation-flow__icon--document"><i></i><i></i><i></i></div>
							<strong>Policies</strong>
							<small>Always aligned and current</small>
							<div class="foundation-flow__tags"><span>Privacy</span><span>Security</span></div>
						</div>
					</div>
				</div>
			</section>

			<section class="px-6 py-14 md:py-24">
				<div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-16">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">One-click policy creation</p>
						<h2 class="heading-section mt-4">Generate policies from reality, not guesswork.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p class="font-semibold text-slate-950">Your policies should reflect how your company actually operates.</p>
							<p>Claire generates customer-facing documentation directly from your source of truth using fully customizable templates.</p>
						</div>
						<p class="mt-7 text-sm font-bold uppercase tracking-[0.12em] text-slate-500">Create and maintain</p>
						<ul class="mt-4 grid gap-3 text-base font-medium text-slate-700 sm:grid-cols-2">
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Privacy Policies</span></li>
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Security Policies</span></li>
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>Subprocessor Lists</span></li>
							<li class="flex items-start gap-3"><span class="mt-1 text-lime-600">✓</span><span>GDPR Records of Processing Activities (RoPA)</span></li>
							<li class="flex items-start gap-3 sm:col-span-2"><span class="mt-1 text-lime-600">✓</span><span>Data Processing Agreements (DPA)</span></li>
						</ul>
						<div class="mt-8 rounded-xl border border-lime-200 bg-lime-50 p-5 text-base leading-7 text-slate-700">
							<p>Every document stays connected to the underlying facts.</p>
							<p class="mt-1 font-bold text-slate-950">Update the facts once. Regenerate everything.</p>
						</div>
					</div>

					<div class="policy-previews" role="img" aria-label="Previews of generated privacy, security, and processing activity documents">
						<div class="policy-preview policy-preview--privacy">
							<div class="policy-preview__header"><span class="policy-preview__logo">C</span><span>Claire</span><i>Current</i></div>
							<p>Privacy Policy</p>
							<h3>How we handle personal data</h3>
							<div class="policy-preview__rule"></div>
							<span class="policy-preview__line policy-preview__line--long"></span>
							<span class="policy-preview__line"></span>
							<span class="policy-preview__line policy-preview__line--short"></span>
							<div class="policy-preview__source"><span></span>Generated from 12 connected facts</div>
						</div>
						<div class="policy-preview policy-preview--security" aria-hidden="true">
							<div class="policy-preview__header"><span class="policy-preview__logo">C</span><span>Claire</span></div>
							<p>Security Policy</p>
							<h3>Protecting company systems</h3>
							<div class="policy-preview__rule"></div>
							<span class="policy-preview__line policy-preview__line--long"></span>
							<span class="policy-preview__line"></span>
						</div>
						<div class="policy-preview policy-preview--ropa" aria-hidden="true">
							<div class="policy-preview__header"><span class="policy-preview__logo">C</span><span>Claire</span></div>
							<p>GDPR RoPA</p>
							<h3>Processing activities</h3>
							<div class="policy-preview__table"><i></i><i></i><i></i><i></i><i></i><i></i></div>
						</div>
						<div class="policy-previews__sync" aria-hidden="true"><span></span>Source facts synced</div>
					</div>
				</div>
			</section>

			<section id="features" class="border-y border-slate-200 bg-white px-6 py-14 md:py-24">
				<div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-16">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Avoid compliance drift</p>
						<h2 class="heading-section mt-4">The fastest way to lose trust is inconsistent documentation.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p>Customers notice when your documents don’t agree with each other.</p>
							<p>And they definitely notice when they don’t match reality.</p>
							<p>Claire continuously checks for inconsistencies, missing information, and documentation gaps before your customers find them.</p>
							<p class="font-semibold text-slate-950">Instead of discovering issues during a customer review, fix them before they become questions.</p>
						</div>
					</div>

					<div class="drift-dashboard" aria-label="Illustrative customer feedback about documentation inconsistencies">
						<div class="drift-dashboard__header">
							<div>
								<span class="drift-dashboard__eyebrow">Customer review feedback</span>
								<strong>Questions you don’t want to receive</strong>
							</div>
							<span class="drift-dashboard__example-label">Illustrative examples</span>
						</div>
						<div class="drift-dashboard__alerts">
							<article class="drift-alert">
								<span class="drift-alert__icon">“</span>
								<div>
									<blockquote>“Your privacy policy states student submissions are retained for 90 days, but your security policy references a 30-day retention period.”</blockquote>
									<p>Fictional customer security reviewer</p>
								</div>
							</article>
							<article class="drift-alert">
								<span class="drift-alert__icon">“</span>
								<div>
									<blockquote>“Your subprocessor list doesn’t include Mixpanel.”</blockquote>
									<p>Fictional procurement lead</p>
								</div>
							</article>
							<article class="drift-alert">
								<span class="drift-alert__icon">“</span>
								<div>
									<blockquote>“Your security policy mentions MFA, but MFA is marked as optional in your access controls.”</blockquote>
									<p>Fictional enterprise buyer</p>
								</div>
							</article>
						</div>
					</div>
				</div>
			</section>

			<section class="px-6 py-14 md:py-24">
				<div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:gap-16">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Customer questionnaires in minutes, not days</p>
						<h2 class="heading-section mt-4">Stop digging through docs for answers.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p class="font-semibold text-slate-950">Enterprise customers don’t just ask for policies.</p>
							<p class="font-semibold text-slate-950">They send spreadsheets.</p>
							<p class="font-semibold text-slate-950">Lots of spreadsheets.</p>
							<p>Claire keeps your privacy, security, vendor, and data handling information in one place, making customer questionnaires dramatically easier to complete.</p>
							<p>Instead of hunting for answers across Slack, Notion, spreadsheets, and old documents, start with a source of truth that’s already organized.</p>
							<p class="font-bold text-slate-950">Less scrambling. More shipping.</p>
						</div>
					</div>

					<div class="questionnaire-demo" role="img" aria-label="Customer security questionnaire with answers generated from an organized source of truth">
						<div class="questionnaire-demo__toolbar">
							<div><span></span><span></span><span></span></div>
							<strong>Enterprise security questionnaire.xlsx</strong>
							<i>42 of 48 answered</i>
						</div>
						<div class="questionnaire-demo__columns"><span>Question</span><span>Answer</span><span>Source</span></div>
						<div class="questionnaire-row">
							<div><b>01</b><span>Is data encrypted at rest?</span></div>
							<p><i>✓</i> Yes, using AES-256 encryption.</p>
							<small>Security Policy</small>
						</div>
						<div class="questionnaire-row">
							<div><b>02</b><span>Do you require MFA?</span></div>
							<p><i>✓</i> Required for all production access.</p>
							<small>Access Controls</small>
						</div>
						<div class="questionnaire-row">
							<div><b>03</b><span>List your subprocessors.</span></div>
							<p><i>✓</i> AWS, Stripe, Auth0, Mixpanel.</p>
							<small>Vendor Inventory</small>
						</div>
						<div class="questionnaire-row questionnaire-row--active">
							<div><b>04</b><span>How long is customer data retained?</span></div>
							<p><i>✓</i> 90 days after account termination.</p>
							<small>Retention Rules</small>
						</div>
						<div class="questionnaire-demo__footer">
							<span><i></i> Answers linked to source facts</span>
							<button type="button" tabindex="-1">Export answers <b>→</b></button>
						</div>
					</div>
				</div>
			</section>

			<section id="early-access" class="px-6 py-14 md:py-24">
				<div class="waitlist-panel mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-300">Join the waitlist</p>
						<h2 class="mt-4 font-heading text-4xl leading-tight text-white md:text-5xl">Build your source of truth before customers start asking.</h2>
						<p class="mt-5 text-lg leading-8 text-slate-300">Get early access to Claire and help shape a simpler way to manage policies, drift, and customer questionnaires.</p>
						<p class="mt-6 text-sm leading-6 text-slate-400">No spam. Occasional product updates and founder interviews.</p>
					</div>
					<form class="waitlist-form rounded-2xl border border-white/10 bg-white p-6 shadow-2xl sm:p-8" novalidate>
						<input class="waitlist-honeypot" name="website" type="url" tabindex="-1" autocomplete="off" aria-hidden="true" />
						<div class="grid gap-5">
							<div>
								<label for="email" class="block text-sm font-semibold text-slate-900">Email</label>
								<input
									id="email"
									name="email"
									type="email"
									required
									placeholder="founder@example.com"
									class="mt-2 min-h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-950 shadow-sm placeholder:text-slate-400 focus:border-lime-500 focus:outline-none focus:ring-4 focus:ring-lime-100"
								/>
							</div>
							<div>
								<label for="blocker" class="block text-sm font-semibold text-slate-900">Biggest compliance blocker <span class="font-normal text-slate-500">(optional)</span></label>
								<textarea
									id="blocker"
									name="blocker"
									rows="4"
									placeholder="Security questionnaire, SOC 2 prep, GDPR questions, vendor review..."
									class="mt-2 w-full resize-y rounded-lg border border-slate-200 bg-white px-4 py-3 text-base text-slate-950 shadow-sm placeholder:text-slate-400 focus:border-lime-500 focus:outline-none focus:ring-4 focus:ring-lime-100"
								></textarea>
							</div>
							<button type="submit" class="inline-flex min-h-12 w-full items-center justify-center rounded-lg bg-lime-300 px-5 text-base font-bold text-slate-950 shadow-sm transition hover:bg-lime-200 disabled:cursor-wait disabled:opacity-60 sm:w-auto">
								Join early access
							</button>
							<p class="waitlist-status hidden text-sm font-medium" role="status" aria-live="polite"></p>
							<p class="text-sm leading-6 text-slate-500">
								Claire provides readiness guidance and organization tools. It does not provide legal advice, certification, or audit assurance.
							</p>
						</div>
					</form>
				</div>
			</section>
		</main>

		<footer class="px-6 py-10">
			<div class="mx-auto flex max-w-6xl flex-col gap-6 border-t border-slate-200 pt-8 md:flex-row md:items-start md:justify-between">
				<div>
					<p class="font-semibold text-slate-950">plyco</p>
					<p class="mt-2 max-w-md text-sm leading-6 text-slate-600">Lightweight compliance readiness for early-stage startups.</p>
					<p class="mt-3 max-w-xl text-xs leading-5 text-slate-500">Readiness guidance only. Not legal advice, certification, or audit assurance.</p>
				</div>
				<nav class="flex flex-wrap gap-5 text-sm font-medium text-slate-600" aria-label="Footer navigation">
					<a class="hover:text-slate-950" href="#early-access">Early access</a>
					<a class="hover:text-slate-950" href="mailto:hello@compliancestarter.com">Contact</a>
					<a class="hover:text-slate-950" href="#early-access">Privacy</a>
				</nav>
			</div>
		</footer>
		<script is:inline define:vars={{ apiUrl }}>
			const form = document.querySelector(".waitlist-form");

			form?.addEventListener("submit", async (event) => {
				event.preventDefault();
				const status = form.querySelector(".waitlist-status");
				const button = form.querySelector("button[type='submit']");
				const data = new FormData(form);
				const email = String(data.get("email") ?? "").trim();

				status.classList.remove("hidden", "text-green-700", "text-red-700");

				if (!email || !email.includes("@")) {
					status.textContent = "Enter a valid email address.";
					status.classList.add("text-red-700");
					return;
				}

				button.disabled = true;
				button.textContent = "Joining...";
				status.textContent = "";

				try {
					const response = await fetch(`${apiUrl}/waitlist`, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							email,
							blocker: String(data.get("blocker") ?? "").trim() || undefined,
							website: String(data.get("website") ?? ""),
						}),
					});

					if (!response.ok) throw new Error("Request failed");

					form.reset();
					status.textContent = "You're on the list. We'll be in touch.";
					status.classList.add("text-green-700");
				} catch {
					status.textContent = "We couldn't save your spot. Please try again.";
					status.classList.add("text-red-700");
				} finally {
					button.disabled = false;
					button.textContent = "Join the waitlist";
				}
			});
		</script>
	</body>
</html>
