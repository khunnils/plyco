---
import DriftFeedbackIllustration from "../components/DriftFeedbackIllustration.astro";
import FoundationFlowIllustration from "../components/FoundationFlowIllustration.astro";
import PolicyMapIllustration from "../components/PolicyMapIllustration.astro";
import PolicyPreviewsIllustration from "../components/PolicyPreviewsIllustration.astro";
import QuestionnaireIllustration from "../components/QuestionnaireIllustration.astro";
import "../styles/global.css";

const apiUrl = import.meta.env.PUBLIC_API_URL ?? "http://localhost:4000";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Plyco — Compliance readiness for early-stage startups</title>
		<meta
			name="description"
			content="A lightweight workspace that helps startups organize policies, vendors, evidence, and security basics before enterprise customers ask for SOC 2 or GDPR readiness."
		/>
		<meta property="og:title" content="Avoid Compliance Debt Early" />
		<meta
			property="og:description"
			content="Lightweight compliance readiness for startups moving toward enterprise customers."
		/>
		<meta property="og:type" content="website" />
	</head>
	<body class="page-enter bg-slate-50 text-slate-950 antialiased">
		<header class="absolute inset-x-0 top-0 z-50">
			<nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-5" aria-label="Main navigation">
				<a href="#" class="flex items-center gap-3 text-lg font-bold tracking-tight text-slate-950" aria-label="Plyco home">
					<img src="/logo.png" alt="" width="360" height="360" class="h-10 w-10 object-contain rounded-md" />
					<span>Plyco</span>
				</a>
				<div class="hidden items-center gap-9 text-sm font-medium text-slate-700 md:flex">
					<a class="transition hover:text-slate-950" href="#problem">All Pages</a>
					<a class="transition hover:text-slate-950" href="#features">Features</a>
					<a class="transition hover:text-slate-950" href="#pricing">Pricing</a>
					<a class="transition hover:text-slate-950" href="mailto:hello@compliancestarter.com">Contact</a>
				</div>
				<a
					href="#early-access"
					class="inline-flex min-h-12 items-center gap-4 rounded-full bg-neutral-950 py-1.5 pl-6 pr-2 text-sm font-bold text-white shadow-sm transition hover:bg-neutral-800"
				>
					Get Started
					<span class="flex h-9 w-9 items-center justify-center rounded-full bg-lime-200 text-xl leading-none text-neutral-950">→</span>
				</a>
			</nav>
		</header>

		<main>
			<section class="relative overflow-hidden bg-white px-6 pb-16 pt-32 md:pb-20 md:pt-36">
				<div class="absolute inset-0 z-0 bg-[linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.06)_1px,transparent_1px)] bg-[size:92px_92px]"></div>
				<div class="absolute inset-x-0 top-0 z-0 h-80 bg-linear-to-b from-white via-white/80 to-transparent"></div>
				<div class="absolute inset-x-0 bottom-0 z-0 h-64 bg-linear-to-t from-slate-50 via-white/90 to-transparent"></div>

				<div class="relative z-10 mx-auto max-w-6xl text-center">
					<div class="mx-auto max-w-4xl">
						<p class="mb-6 inline-flex rounded-full border border-lime-200 bg-lime-100 px-4 py-2 text-sm font-bold text-slate-900">
							Compliance readiness for early-stage startups
						</p>
						<h1 class="heading-hero">
							Stop winging your policy docs
						</h1>
						<p class="mx-auto mt-7 max-w-2xl text-lg leading-8 text-slate-600 md:text-xl">
							A lightweight policy management platform for early-stage startups building toward enterprise customers.
						</p>
						<div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
							<a
								href="#early-access"
								class="inline-flex min-h-14 items-center gap-4 rounded-full bg-neutral-950 py-1.5 pl-7 pr-2 text-base font-bold text-white shadow-sm transition hover:bg-neutral-800"
							>
								Join the waitlist
								<span class="flex h-10 w-10 items-center justify-center rounded-full bg-lime-200 text-2xl leading-none text-neutral-950">→</span>
							</a>
							<a
								href="#features"
								class="inline-flex min-h-14 items-center gap-4 rounded-full border border-slate-200 bg-white py-1.5 pl-7 pr-2 text-base font-bold text-slate-900 shadow-sm transition hover:bg-slate-100"
							>
								See what it helps with
								<span class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-2xl leading-none text-neutral-950">→</span>
							</a>
						</div>
						<p class="mx-auto mt-5 max-w-xl text-sm leading-6 text-slate-500">
							For founders preparing for SOC 2, GDPR readiness, security reviews, and enterprise pilots.
						</p>
					</div>

					<PolicyMapIllustration />
				</div>
			</section>

			<section id="problem" class="border-y border-slate-200 bg-white px-6 py-14 md:py-24">
				<div class="mx-auto max-w-6xl text-center">
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Model the foundations</p>
						<h2 class="text-5xl mt-4">Model the facts. </h2>
						<h2 class="text-5xl mt-4">Generate the policies. </h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p class="font-semibold text-slate-950">Most policy tools start with templates. We start with your business.</p>
							<p>
								Define the services you offer, the data you collect, the activities you perform, and the vendors you rely on. 
								<br/>Plyco turns that information into structured documents that stay consistent.
							</p>
					</div>

					<FoundationFlowIllustration />
				</div>
			</section>

			<section class="px-6 py-10 md:py-24">
				<div class="mx-auto max-w-6xl">
					<div class="mx-auto max-w-4xl text-center">
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">One-click policy creation</p>
						<h2 class="mt-4 text-5xl">Generate policies from reality, <br/>not guesswork.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p class="font-semibold text-slate-950">Your policies should reflect how your company actually operates.</p>
							<p>Plyco generates customer-facing documentation directly from your source of truth using fully customizable templates.</p>
						</div>
					</div>

					<div class="mx-auto mt-12 max-w-5xl">
						<PolicyPreviewsIllustration />
						<p class="mx-auto mt-3 max-w-2xl text-center text-base leading-7 text-slate-500">
							We ship with privacy, security, GDPR, and more. Add any additional templates you need.
						</p>
					</div>
				</div>
			</section>

			<section id="features" class="border-y border-slate-200 bg-white px-6 py-14 md:py-28">
				<div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-16">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Avoid compliance drift</p>
						<h2 class="heading-section mt-4">Nothing erodes trust like inconsistent documentation.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p>Customers notice when your documents don’t agree with each other. And they definitely notice when they don’t match reality.</p>
							<p>Plyco continuously checks for inconsistencies, missing information, and documentation gaps before your customers find them.</p>
							<p class="font-semibold text-slate-950">Instead of discovering issues during a customer review, fix them before they become questions.</p>
						</div>
					</div>

					<DriftFeedbackIllustration />
				</div>
			</section>

			<section class="px-6 py-14 md:py-24">
				<div class="mx-auto grid max-w-6xl gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-center lg:gap-16">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Customer questionnaires in minutes, not days</p>
						<h2 class="heading-section mt-4">Stop digging through docs for answers.</h2>
						<div class="mt-6 space-y-4 text-lg leading-8 text-slate-600">
							<p class="font-semibold text-slate-950">Enterprise customers don’t just ask for policies.</p>
							<p class="font-semibold text-slate-950">They send spreadsheets.</p>
							<p class="font-semibold text-slate-950">Lots of spreadsheets.</p>
							<p>Plyco keeps your privacy, security, vendor, and data handling information in one place, making customer questionnaires dramatically easier to complete.</p>
							<p>Instead of hunting for answers across Slack, Notion, spreadsheets, and old documents, start with a source of truth that’s already organized.</p>
							<p class="font-bold text-slate-950">Less scrambling. More shipping.</p>
						</div>
					</div>

					<QuestionnaireIllustration />
				</div>
			</section>

			<section class="border-y border-slate-200 bg-white px-6 py-14 md:py-24">
				<div class="mx-auto max-w-6xl">
					<div class="mx-auto max-w-3xl text-center">
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Take control of your policies</p>
						<h2 class="heading-section mt-4">One dashboard for the work behind every security review.</h2>
						<p class="mt-6 text-lg leading-8 text-slate-600">
							Track policy coverage, open recommendations, document status, and the operational details customers ask about before review season turns into a scramble.
						</p>
					</div>

					<div class="group mx-auto mt-12 max-w-5xl rounded-2xl border border-slate-200 bg-slate-50 p-2 shadow-[0_24px_70px_rgba(15,23,42,0.1)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_30px_90px_rgba(15,23,42,0.16)] motion-reduce:transition-none motion-reduce:hover:translate-y-0">
						<img
							src="/dashboard.jpg"
							alt="Plyco dashboard showing policy readiness progress and recommendations"
							width="3016"
							height="2516"
							loading="lazy"
							class="aspect-[3016/2516] w-full rounded-xl border border-slate-200 object-cover object-top shadow-sm transition duration-300 group-hover:scale-[1.006] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
						/>
					</div>
				</div>
			</section>

			<section id="pricing" class="px-6 py-14 md:py-24">
				<div class="mx-auto max-w-6xl">
					<div class="mx-auto max-w-3xl text-center">
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-700">Pricing</p>
						<h2 class="heading-section mt-4">Start small, stay organized as reviews get serious.</h2>
						<p class="mt-6 text-lg leading-8 text-slate-600">
							Simple monthly plans for keeping your policies, vendors, evidence, and customer answers in sync.
						</p>
						<p class="mt-3 text-base font-bold text-slate-950">30-day free trial. No credit card required.</p>
					</div>

					<div class="mx-auto mt-12 grid max-w-4xl gap-5 md:grid-cols-2">
						<article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_14px_35px_rgba(15,23,42,0.07)] transition duration-300 hover:-translate-y-1 hover:border-lime-300 hover:shadow-[0_20px_55px_rgba(15,23,42,0.11)] motion-reduce:transition-none motion-reduce:hover:translate-y-0">
							<div class="flex min-h-28 flex-col justify-between gap-5">
								<div>
									<h3 class="font-heading text-3xl text-slate-950">Solopreneur</h3>
									<p class="mt-2 text-base leading-7 text-slate-600">For founders getting their first customer-facing policies under control.</p>
								</div>
								<p class="flex items-end gap-2 text-slate-950">
									<span class="font-heading text-5xl leading-none">$29</span>
									<span class="pb-1 text-base font-semibold text-slate-500">/ month</span>
								</p>
							</div>
							<ul class="mt-8 grid gap-3 text-sm font-medium leading-6 text-slate-700">
								<li class="flex gap-3"><span class="text-lime-700">✓</span><span>Policy and vendor source of truth</span></li>
								<li class="flex gap-3"><span class="text-lime-700">✓</span><span>Document generation from structured inputs</span></li>
								<li class="flex gap-3"><span class="text-lime-700">✓</span><span>Readiness recommendations and drift checks</span></li>
							</ul>
							<a href="#early-access" class="mt-8 inline-flex min-h-12 w-full items-center justify-center rounded-lg border border-slate-200 bg-white px-5 text-base font-bold text-slate-950 shadow-sm transition hover:bg-slate-100">
								Start free trial
							</a>
							<p class="mt-3 text-center text-xs font-semibold text-slate-500">No credit card required</p>
						</article>

						<article class="rounded-2xl border border-slate-950 bg-slate-950 p-6 text-white shadow-[0_20px_60px_rgba(15,23,42,0.2)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_75px_rgba(15,23,42,0.28)] motion-reduce:transition-none motion-reduce:hover:translate-y-0">
							<div class="flex min-h-28 flex-col justify-between gap-5">
								<div>
									<h3 class="font-heading text-3xl">Team</h3>
									<p class="mt-2 text-base leading-7 text-slate-300">For small teams coordinating policy work, vendors, and customer reviews together.</p>
								</div>
								<p class="flex items-end gap-2">
									<span class="font-heading text-5xl leading-none">$49</span>
									<span class="pb-1 text-base font-semibold text-slate-400">/ month</span>
								</p>
							</div>
							<ul class="mt-8 grid gap-3 text-sm font-medium leading-6 text-slate-200">
								<li class="flex gap-3"><span class="text-lime-300">✓</span><span>Everything in Solopreneur</span></li>
								<li class="flex gap-3"><span class="text-lime-300">✓</span><span>Shared workspace for policy and vendor updates</span></li>
								<li class="flex gap-3"><span class="text-lime-300">✓</span><span>Team-ready customer questionnaire support</span></li>
							</ul>
							<a href="#early-access" class="mt-8 inline-flex min-h-12 w-full items-center justify-center rounded-lg bg-lime-300 px-5 text-base font-bold text-slate-950 shadow-sm transition hover:bg-lime-200">
								Start free trial
							</a>
							<p class="mt-3 text-center text-xs font-semibold text-slate-400">No credit card required</p>
						</article>
					</div>
				</div>
			</section>

			<section id="early-access" class="px-6 py-14 md:py-24">
				<div class="waitlist-panel mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
					<div>
						<p class="text-sm font-bold uppercase tracking-[0.16em] text-lime-300">Join the waitlist</p>
						<h2 class="mt-4 font-heading text-4xl leading-tight text-white md:text-5xl">Build your source of truth before customers start asking.</h2>
						<p class="mt-5 text-lg leading-8 text-slate-300">Get early access to Plyco and help shape a simpler way to manage policies, drift, and customer questionnaires.</p>
						<p class="mt-6 text-sm leading-6 text-slate-400">No spam. Occasional product updates and founder interviews.</p>
					</div>
					<form class="waitlist-form rounded-2xl border border-white/10 bg-white p-6 shadow-2xl sm:p-8" novalidate>
						<input class="waitlist-honeypot" name="website" type="url" tabindex="-1" autocomplete="off" aria-hidden="true" />
						<div class="grid gap-5">
							<div>
								<label for="email" class="block text-sm font-semibold text-slate-900">Email</label>
								<input
									id="email"
									name="email"
									type="email"
									required
									placeholder="founder@example.com"
									class="mt-2 min-h-12 w-full rounded-lg border border-slate-200 bg-white px-4 text-base text-slate-950 shadow-sm placeholder:text-slate-400 focus:border-lime-500 focus:outline-none focus:ring-4 focus:ring-lime-100"
								/>
							</div>
							<div>
								<label for="blocker" class="block text-sm font-semibold text-slate-900">Biggest compliance blocker <span class="font-normal text-slate-500">(optional)</span></label>
								<textarea
									id="blocker"
									name="blocker"
									rows="4"
									placeholder="Security questionnaire, SOC 2 prep, GDPR questions, vendor review..."
									class="mt-2 w-full resize-y rounded-lg border border-slate-200 bg-white px-4 py-3 text-base text-slate-950 shadow-sm placeholder:text-slate-400 focus:border-lime-500 focus:outline-none focus:ring-4 focus:ring-lime-100"
								></textarea>
							</div>
							<button type="submit" class="inline-flex min-h-12 w-full items-center justify-center rounded-lg bg-lime-300 px-5 text-base font-bold text-slate-950 shadow-sm transition hover:bg-lime-200 disabled:cursor-wait disabled:opacity-60 sm:w-auto">
								Join early access
							</button>
							<p class="waitlist-status hidden text-sm font-medium" role="status" aria-live="polite"></p>
							<p class="text-sm leading-6 text-slate-500">
								Plyco provides readiness guidance and organization tools. It does not provide legal advice, certification, or audit assurance.
							</p>
						</div>
					</form>
				</div>
			</section>
		</main>

		<footer class="px-6 py-10">
			<div class="mx-auto flex max-w-6xl flex-col gap-6 border-t border-slate-200 pt-8 md:flex-row md:items-start md:justify-between">
				<div>
					<p class="font-semibold text-slate-950">plyco</p>
					<p class="mt-2 max-w-md text-sm leading-6 text-slate-600">Lightweight compliance readiness for early-stage startups.</p>
					<p class="mt-3 max-w-xl text-xs leading-5 text-slate-500">Readiness guidance only. Not legal advice, certification, or audit assurance.</p>
				</div>
				<nav class="flex flex-wrap gap-5 text-sm font-medium text-slate-600" aria-label="Footer navigation">
					<a class="hover:text-slate-950" href="#early-access">Early access</a>
					<a class="hover:text-slate-950" href="mailto:hello@compliancestarter.com">Contact</a>
					<a class="hover:text-slate-950" href="#early-access">Privacy</a>
				</nav>
			</div>
		</footer>
		<script is:inline define:vars={{ apiUrl }}>
			const form = document.querySelector(".waitlist-form");

			form?.addEventListener("submit", async (event) => {
				event.preventDefault();
				const status = form.querySelector(".waitlist-status");
				const button = form.querySelector("button[type='submit']");
				const data = new FormData(form);
				const email = String(data.get("email") ?? "").trim();

				status.classList.remove("hidden", "text-green-700", "text-red-700");

				if (!email || !email.includes("@")) {
					status.textContent = "Enter a valid email address.";
					status.classList.add("text-red-700");
					return;
				}

				button.disabled = true;
				button.textContent = "Joining...";
				status.textContent = "";

				try {
					const response = await fetch(`${apiUrl}/waitlist`, {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify({
							email,
							blocker: String(data.get("blocker") ?? "").trim() || undefined,
							website: String(data.get("website") ?? ""),
						}),
					});

					if (!response.ok) throw new Error("Request failed");

					form.reset();
					status.textContent = "You're on the list. We'll be in touch.";
					status.classList.add("text-green-700");
				} catch {
					status.textContent = "We couldn't save your spot. Please try again.";
					status.classList.add("text-red-700");
				} finally {
					button.disabled = false;
					button.textContent = "Join the waitlist";
				}
			});
		</script>
	</body>
</html>
