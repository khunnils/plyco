generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                    String                   @id(map: "organizations_pkey") @default(cuid())
  companyName           String                   @map("company_name")
  legalEntityName       String                   @default("") @map("legal_entity_name")
  website               String                   @default("")
  contactEmail          String                   @default("") @map("contact_email")
  securityContactEmail  String                   @default("") @map("security_contact_email")
  privacyContactEmail   String                   @default("") @map("privacy_contact_email")
  country               String                   @default("")
  address               String                   @default("")
  employeeCount         Int                      @map("employee_count")
  industries            String[]
  regions               String[]
  handlesPii            Boolean                  @map("handles_pii")
  handlesSensitiveData  Boolean                  @map("handles_sensitive_data")
  complianceGoals       String[]                 @map("compliance_goals")
  services              ServiceProfile[]
  privacyProfile        PrivacyProfile?
  infrastructureProfile InfrastructureProfile?
  dataHandlingProfile   DataHandlingProfile?
  accessProfile         AccessProfile?
  dataTypes             OrganizationDataType[]
  businessActivities    BusinessActivity[]
  vendorMasters         VendorMaster[]
  serviceVendorUses     ServiceVendorUse[]
  templates             Template[]
  documents             Document[]
  vendors               OrganizationProvider[]
  memberships           OrganizationMembership[]
  codeSets              OrganizationCodeSet[]
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  @@map("organizations")
}

model Country {
  code      String   @id(map: "countries_pkey")
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("countries")
}

model SystemCodeSet {
  id               String                @id(map: "system_code_sets_pkey")
  airtableRecordId String                @unique(map: "system_code_sets_airtable_record_id_key") @map("airtable_record_id")
  name             String
  description      String                @default("")
  isSystem         Boolean               @default(false) @map("is_system")
  codes            SystemCode[]
  organizationSets OrganizationCodeSet[]
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@map("system_code_sets")
}

model SystemCode {
  id               String        @id(map: "system_codes_pkey") @default(cuid())
  codeSetId        String        @map("code_set_id")
  codeSet          SystemCodeSet @relation(fields: [codeSetId], references: [id], onDelete: Cascade, map: "system_codes_code_set_id_fkey")
  airtableRecordId String        @unique(map: "system_codes_airtable_record_id_key") @map("airtable_record_id")
  codeId           String        @map("code_id")
  name             String
  sortOrder        Int           @default(0) @map("sort_order")
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@unique([codeSetId, codeId], map: "system_codes_code_set_id_code_id_key")
  @@index([codeSetId], map: "idx_system_codes_code_set_id")
  @@map("system_codes")
}

model OrganizationCodeSet {
  id              String             @id(map: "organization_code_sets_pkey") @default(cuid())
  organizationId  String             @map("organization_id")
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_code_sets_organization_id_fkey")
  systemCodeSetId String             @map("system_code_set_id")
  systemCodeSet   SystemCodeSet      @relation(fields: [systemCodeSetId], references: [id], onDelete: Restrict, map: "organization_code_sets_system_code_set_id_fkey")
  name            String
  description     String             @default("")
  codes           OrganizationCode[]
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@unique([organizationId, systemCodeSetId], map: "organization_code_sets_organization_id_system_code_set_id_key")
  @@index([organizationId], map: "idx_organization_code_sets_organization_id")
  @@index([systemCodeSetId], map: "idx_organization_code_sets_system_code_set_id")
  @@map("organization_code_sets")
}

model OrganizationCode {
  id                    String              @id(map: "organization_codes_pkey") @default(cuid())
  organizationCodeSetId String              @map("organization_code_set_id")
  organizationCodeSet   OrganizationCodeSet @relation(fields: [organizationCodeSetId], references: [id], onDelete: Cascade, map: "organization_codes_organization_code_set_id_fkey")
  systemCodeId          String?             @map("system_code_id")
  codeId                String              @map("code_id")
  name                  String
  sortOrder             Int                 @default(0) @map("sort_order")
  active                Boolean             @default(true)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@unique([organizationCodeSetId, codeId], map: "organization_codes_code_set_id_code_id_key")
  @@index([organizationCodeSetId], map: "idx_organization_codes_organization_code_set_id")
  @@index([systemCodeId], map: "idx_organization_codes_system_code_id")
  @@map("organization_codes")
}

model User {
  id                      String                   @id(map: "users_pkey") @default(cuid())
  googleSubject           String                   @unique(map: "users_google_subject_key") @map("google_subject")
  email                   String                   @unique(map: "users_email_key")
  name                    String
  picture                 String?
  memberships             OrganizationMembership[]
  policyOwnedTemplates    Template[]               @relation("TemplatePolicyOwner")
  policyApprovedTemplates Template[]               @relation("TemplatePolicyApprover")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")

  @@map("users")
}

model OrganizationMembership {
  id             String       @id(map: "organization_memberships_pkey") @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade, map: "organization_memberships_user_id_fkey")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_memberships_organization_id_fkey")
  role           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([userId, organizationId], map: "organization_memberships_user_id_organization_id_key")
  @@index([userId], map: "idx_organization_memberships_user_id")
  @@index([organizationId], map: "idx_organization_memberships_organization_id")
  @@map("organization_memberships")
}

model ServiceProfile {
  id                  String                 @id(map: "service_profiles_pkey") @default(cuid())
  organizationId      String                 @map("organization_id")
  organization        Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "service_profiles_organization_id_fkey")
  vendors             OrganizationProvider[]
  businessActivities  ServiceBusinessActivity[]
  serviceVendorUses   ServiceVendorUse[]
  serviceName         String                 @default("") @map("service_name")
  serviceDescription  String                 @default("") @map("service_description")
  serviceUrl          String                 @default("") @map("service_url")
  userTypes           String[]               @default([]) @map("user_types")
  customerTypes       String[]               @default([]) @map("customer_types")
  availabilityRegions String[]               @default([]) @map("availability_regions")
  childrenDirected    Boolean                @default(false) @map("children_directed")
  minimumUserAge      Int                    @default(0) @map("minimum_user_age")
  usesCookies         Boolean                @default(false) @map("uses_cookies")
  cookieTypes         String[]               @default([]) @map("cookie_types")
  primaryHostingRegion String                @default("") @map("primary_hosting_region")
  dataResidencyOptions String[]              @default([]) @map("data_residency_options")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  @@index([organizationId], map: "idx_service_profiles_organization_id")
  @@map("service_profiles")
}

model PrivacyProfile {
  id                            String       @id(map: "privacy_profiles_pkey") @default(cuid())
  organizationId                String       @unique(map: "privacy_profiles_organization_id_key") @map("organization_id")
  organization                  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "privacy_profiles_organization_id_fkey")
  supportedRights               String[]     @default([]) @map("supported_rights")
  requestMethods                String[]     @default([]) @map("request_methods")
  responseTimelineDays          Int          @default(0) @map("response_timeline_days")
  identityVerificationRequired  Boolean      @default(false) @map("identity_verification_required")
  authorizedAgentSupported      Boolean      @default(false) @map("authorized_agent_supported")
  appealProcessExists           Boolean      @default(false) @map("appeal_process_exists")
  cookieConsentMechanism        String       @default("") @map("cookie_consent_mechanism")
  doNotTrackResponse            Boolean      @default(false) @map("do_not_track_response")
  globalPrivacyControlSupported Boolean      @default(false) @map("global_privacy_control_supported")
  sendsMarketingEmails          Boolean      @default(false) @map("sends_marketing_emails")
  marketingOptOutMethod         String       @default("") @map("marketing_opt_out_method")
  transactionalEmailsSent       Boolean      @default(false) @map("transactional_emails_sent")
  crossBorderTransfers          Boolean      @default(false) @map("cross_border_transfers")
  transferMechanisms            String[]     @default([]) @map("transfer_mechanisms")
  sellsOrSharesData             Boolean      @default(false) @map("sells_or_shares_data")
  doNotSellLink                 String       @default("") @map("do_not_sell_link")
  dpoName                       String       @default("") @map("dpo_name")
  dpoEmail                      String       @default("") @map("dpo_email")
  euRepresentativeName          String       @default("") @map("eu_representative_name")
  euRepresentativeAddress       String       @default("") @map("eu_representative_address")
  usesAutomatedDecisionMaking   Boolean      @default(false) @map("uses_automated_decision_making")
  createdAt                     DateTime     @default(now()) @map("created_at")
  updatedAt                     DateTime     @updatedAt @map("updated_at")

  @@map("privacy_profiles")
}

model InfrastructureProfile {
  id                             String       @id(map: "infrastructure_profiles_pkey") @default(cuid())
  organizationId                 String       @unique(map: "infrastructure_profiles_organization_id_key") @map("organization_id")
  organization                   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "infrastructure_profiles_organization_id_fkey")
  mfaEnabled                     Boolean      @map("mfa_enabled")
  encryptedDevicesRequired       Boolean      @map("encrypted_devices_required")
  backupsEnabled                 Boolean      @map("backups_enabled")
  centralizedLoggingEnabled      Boolean      @map("centralized_logging_enabled")
  atRestAlgorithm                String       @default("") @map("at_rest_algorithm")
  inTransitMinimumTlsVersion     String       @default("") @map("in_transit_minimum_tls_version")
  keyManagementProvider          String       @default("") @map("key_management_provider")
  logRetentionDays               Int          @default(0) @map("log_retention_days")
  securityMonitoringOwner        String       @default("") @map("security_monitoring_owner")
  scanningCadence                String       @default("") @map("scanning_cadence")
  patchingSlaCriticalDays        Int          @default(0) @map("patching_sla_critical_days")
  patchingSlaHighDays            Int          @default(0) @map("patching_sla_high_days")
  incidentResponsePlanExists     Boolean      @default(false) @map("incident_response_plan_exists")
  incidentNotificationTimeline   String       @default("") @map("incident_notification_timeline")
  customerNotificationProcess    String       @default("") @map("customer_notification_process")
  incidentResponseLastTestedDate String       @default("") @map("incident_response_last_tested_date")
  backupCadence                  String       @default("") @map("backup_cadence")
  backupRetentionDays            Int          @default(0) @map("backup_retention_days")
  restoreTestingCadence          String       @default("") @map("restore_testing_cadence")
  vendorReviewRequired           Boolean      @default(false) @map("vendor_review_required")
  vendorReviewCadence            String       @default("") @map("vendor_review_cadence")
  dpaRequiredForProcessors       Boolean      @default(false) @map("dpa_required_for_processors")
  createdAt                      DateTime     @default(now()) @map("created_at")
  updatedAt                      DateTime     @updatedAt @map("updated_at")

  @@map("infrastructure_profiles")
}

model DataHandlingProfile {
  id                          String       @id(map: "data_handling_profiles_pkey") @default(cuid())
  organizationId              String       @unique(map: "data_handling_profiles_organization_id_key") @map("organization_id")
  organization                Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "data_handling_profiles_organization_id_fkey")
  storesPii                   Boolean      @map("stores_pii")
  storesHealthcareData        Boolean      @map("stores_healthcare_data")
  encryptionAtRest            Boolean      @map("encryption_at_rest")
  encryptionInTransit         Boolean      @map("encryption_in_transit")
  productionDataInDevelopment Boolean      @map("production_data_in_development")
  retentionPolicyExists       Boolean      @map("retention_policy_exists")
  createdAt                   DateTime     @default(now()) @map("created_at")
  updatedAt                   DateTime     @updatedAt @map("updated_at")

  @@map("data_handling_profiles")
}

model OrganizationDataType {
  id                     String           @id(map: "organization_data_types_pkey") @default(cuid())
  organizationId         String           @map("organization_id")
  organization           Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_data_types_organization_id_fkey")
  name                   String
  description            String
  subjectTypes           String[]         @default([]) @map("subject_types")
  collectionMethods      String[]         @default([]) @map("collection_methods")
  retentionDays          Int              @default(0) @map("retention_days")
  isSensitive            Boolean          @map("is_sensitive")
  isRequired             Boolean          @default(false) @map("is_required")
  vendorDataTypes        VendorUseDataType[]
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  @@unique([organizationId, name], map: "organization_data_types_organization_id_name_key")
  @@index([organizationId], map: "idx_organization_data_types_organization_id")
  @@map("organization_data_types")
}

model BusinessActivity {
  id                 String                    @id(map: "business_activities_pkey") @default(cuid())
  organizationId     String                    @map("organization_id")
  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "business_activities_organization_id_fkey")
  name               String
  purpose            String                    @default("")
  role               String                    @default("")
  legalBasis         String[]                  @default([]) @map("legal_basis")
  services           ServiceBusinessActivity[]
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")

  @@unique([organizationId, name], map: "business_activities_organization_id_name_key")
  @@index([organizationId], map: "idx_business_activities_organization_id")
  @@map("business_activities")
}

model ServiceBusinessActivity {
  id                 String           @id(map: "service_business_activities_pkey") @default(cuid())
  serviceId          String           @map("service_id")
  service            ServiceProfile   @relation(fields: [serviceId], references: [id], onDelete: Cascade, map: "service_business_activities_service_id_fkey")
  businessActivityId String           @map("business_activity_id")
  businessActivity   BusinessActivity @relation(fields: [businessActivityId], references: [id], onDelete: Cascade, map: "service_business_activities_business_activity_id_fkey")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([serviceId, businessActivityId], map: "service_business_activities_service_id_business_activity_id_key")
  @@index([serviceId], map: "idx_service_business_activities_service_id")
  @@index([businessActivityId], map: "idx_service_business_activities_business_activity_id")
  @@map("service_business_activities")
}

model AccessProfile {
  id                         String       @id(map: "access_profiles_pkey") @default(cuid())
  organizationId             String       @unique(map: "access_profiles_organization_id_key") @map("organization_id")
  organization               Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "access_profiles_organization_id_fkey")
  mfaRequired                Boolean      @map("mfa_required")
  ssoEnabled                 Boolean      @map("sso_enabled")
  sharedAccountsExist        Boolean      @map("shared_accounts_exist")
  offboardingProcessExists   Boolean      @map("offboarding_process_exists")
  accessReviewsPerformed     Boolean      @map("access_reviews_performed")
  privilegedAccessRestricted Boolean      @map("privileged_access_restricted")
  leastPrivilege             Boolean      @default(false) @map("least_privilege")
  roleBasedAccess            Boolean      @default(false) @map("role_based_access")
  accessReviewCadence        String       @default("") @map("access_review_cadence")
  adminApprovalRequired      Boolean      @default(false) @map("admin_approval_required")
  passwordManagerRequired    Boolean      @default(false) @map("password_manager_required")
  createdAt                  DateTime     @default(now()) @map("created_at")
  updatedAt                  DateTime     @updatedAt @map("updated_at")

  @@map("access_profiles")
}

model OrganizationProvider {
  id                    String           @id(map: "organization_providers_pkey") @default(cuid())
  organizationId        String           @map("organization_id")
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "vendors_organization_id_fkey")
  serviceId             String?          @map("service_id")
  service               ServiceProfile?  @relation(fields: [serviceId], references: [id], onDelete: Cascade, map: "organization_providers_service_id_fkey")
  providerId            String?          @map("provider_id")
  systemType            String?          @map("system_type")
  name                  String
  legalName             String           @default("") @map("legal_name")
  displayName           String           @default("") @map("display_name")
  providerOrganizationName      String   @default("") @map("provider_organization_name")
  providerOrganizationLegalName String   @default("") @map("provider_organization_legal_name")
  privacyPolicyUrl      String           @default("") @map("privacy_policy_url")
  dpaUrl                String           @default("") @map("dpa_url")
  securityPageUrl       String           @default("") @map("security_page_url")
  category              String
  purpose               String
  countryOfRegistration String           @default("") @map("country_of_registration")
  hasSubprocessors      Boolean          @map("has_subprocessors")
  dataProcessingLevel   String           @default("limited") @map("data_processing_level")
  dpaStatus             String           @map("dpa_status")
  dataRegions           String[]         @map("data_regions")
  criticality           String
  owner                 String?
  notes                 String?
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  @@unique([organizationId, serviceId, systemType, providerId], map: "organization_providers_org_service_system_provider_key")
  @@index([organizationId], map: "idx_organization_providers_organization_id")
  @@index([serviceId], map: "idx_organization_providers_service_id")
  @@index([providerId], map: "idx_organization_providers_provider_id")
  @@index([systemType], map: "idx_organization_providers_system_type")
  @@map("organization_providers")
}

model VendorMaster {
  id                            String             @id(map: "vendors_pkey") @default(cuid())
  organizationId                String             @map("organization_id")
  organization                  Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "vendors_organization_id_fkey")
  providerId                    String?            @map("provider_id")
  name                          String
  legalName                     String             @default("") @map("legal_name")
  displayName                   String             @default("") @map("display_name")
  providerOrganizationName      String             @default("") @map("provider_organization_name")
  providerOrganizationLegalName String             @default("") @map("provider_organization_legal_name")
  privacyPolicyUrl              String             @default("") @map("privacy_policy_url")
  dpaUrl                        String             @default("") @map("dpa_url")
  securityPageUrl               String             @default("") @map("security_page_url")
  category                      String
  countryOfRegistration         String             @default("") @map("country_of_registration")
  hasSubprocessors              Boolean            @default(false) @map("has_subprocessors")
  criticality                   String
  owner                         String?
  notes                         String?
  serviceUses                   ServiceVendorUse[]
  createdAt                     DateTime           @default(now()) @map("created_at")
  updatedAt                     DateTime           @updatedAt @map("updated_at")

  @@unique([organizationId, name], map: "vendors_organization_id_name_key")
  @@index([organizationId], map: "idx_vendors_organization_id")
  @@index([providerId], map: "idx_vendors_provider_id")
  @@map("vendors")
}

model ServiceVendorUse {
  id                  String              @id(map: "service_vendor_uses_pkey") @default(cuid())
  organizationId      String              @map("organization_id")
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "service_vendor_uses_organization_id_fkey")
  serviceId           String              @map("service_id")
  service             ServiceProfile      @relation(fields: [serviceId], references: [id], onDelete: Cascade, map: "service_vendor_uses_service_id_fkey")
  vendorId            String              @map("vendor_id")
  vendor              VendorMaster        @relation(fields: [vendorId], references: [id], onDelete: Cascade, map: "service_vendor_uses_vendor_id_fkey")
  purpose             String
  dataProcessingLevel String              @default("limited") @map("data_processing_level")
  dpaStatus           String              @map("dpa_status")
  dataRegions         String[]            @default([]) @map("data_regions")
  notes               String?
  dataTypes           VendorUseDataType[]
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  @@unique([serviceId, vendorId], map: "service_vendor_uses_service_id_vendor_id_key")
  @@index([organizationId], map: "idx_service_vendor_uses_organization_id")
  @@index([serviceId], map: "idx_service_vendor_uses_service_id")
  @@index([vendorId], map: "idx_service_vendor_uses_vendor_id")
  @@map("service_vendor_uses")
}

model Template {
  id                       String       @id(map: "templates_pkey") @default(cuid())
  organizationId           String       @map("organization_id")
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "templates_organization_id_fkey")
  name                     String
  slug                     String
  sourceSystemTemplateSlug String       @map("source_system_template_slug")
  content                  String
  policyEffectiveDate      String       @default("") @map("policy_effective_date")
  policyLastReviewedDate   String       @default("") @map("policy_last_reviewed_date")
  policyVersion            String       @default("") @map("policy_version")
  policyOwnerUserId        String?      @map("policy_owner_user_id")
  policyOwner              User?        @relation("TemplatePolicyOwner", fields: [policyOwnerUserId], references: [id], onDelete: SetNull, map: "templates_policy_owner_user_id_fkey")
  policyApproverUserId     String?      @map("policy_approver_user_id")
  policyApprover           User?        @relation("TemplatePolicyApprover", fields: [policyApproverUserId], references: [id], onDelete: SetNull, map: "templates_policy_approver_user_id_fkey")
  policyReviewCadence      String       @default("") @map("policy_review_cadence")
  documents                Document[]
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, slug], map: "templates_organization_id_slug_key")
  @@index([organizationId], map: "idx_templates_organization_id")
  @@index([policyOwnerUserId], map: "idx_templates_policy_owner_user_id")
  @@index([policyApproverUserId], map: "idx_templates_policy_approver_user_id")
  @@index([sourceSystemTemplateSlug], map: "idx_templates_source_system_template_slug")
  @@map("templates")
}

model Document {
  id              String       @id(map: "documents_pkey") @default(cuid())
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "documents_organization_id_fkey")
  templateId      String       @map("template_id")
  template        Template     @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "documents_template_id_fkey")
  title           String
  renderedContent String       @map("rendered_content")
  pdfObjectPath   String?      @map("pdf_object_path")
  sourceHash      String       @map("source_hash")
  generatedAt     DateTime     @default(now()) @map("generated_at")

  @@unique([organizationId, templateId], map: "documents_organization_id_template_id_key")
  @@index([organizationId], map: "idx_documents_organization_id")
  @@index([templateId], map: "idx_documents_template_id")
  @@map("documents")
}

model VendorUseDataType {
  id                     String               @id(map: "vendor_data_types_pkey") @default(cuid())
  serviceVendorUseId     String               @map("service_vendor_use_id")
  serviceVendorUse       ServiceVendorUse     @relation(fields: [serviceVendorUseId], references: [id], onDelete: Cascade, map: "vendor_data_types_service_vendor_use_id_fkey")
  organizationDataTypeId String               @map("organization_data_type_id")
