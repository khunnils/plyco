generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WaitlistEntry {
  id        String   @id(map: "waitlist_entries_pkey") @default(cuid())
  email     String   @unique(map: "waitlist_entries_email_key")
  blocker   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("waitlist_entries")
}

model Organization {
  id                    String                   @id(map: "organizations_pkey") @default(cuid())
  companyName           String                   @map("company_name")
  legalEntityName       String?                  @map("legal_entity_name")
  website               String?
  contactEmail          String?                  @map("contact_email")
  securityContactEmail  String?                  @map("security_contact_email")
  privacyContactEmail   String?                  @map("privacy_contact_email")
  country               String?
  address               String?
  employeeCount         Int?                     @map("employee_count")
  industries            Json?
  regions               Json?
  handlesPii            Boolean?                 @map("handles_pii")
  handlesSensitiveData  Boolean?                 @map("handles_sensitive_data")
  storesPii             Boolean?                 @map("stores_pii")
  storesHealthcareData  Boolean?                 @map("stores_healthcare_data")
  complianceGoals       Json?                    @map("compliance_goals")
  services              ServiceProfile[]
  privacyProfile        PrivacyProfile?
  infrastructureProfile InfrastructureProfile?
  securityProfile       SecurityProfile?
  accessProfile         AccessProfile?
  dataTypes             OrganizationDataType[]
  businessActivities    BusinessActivity[]
  organizationProviders OrganizationProvider[]
  serviceProviderUsage  ServiceProviderUsage[]
  templates             Template[]
  documents             Document[]
  memberships           OrganizationMembership[]
  invitations           OrganizationInvitation[]
  apiKeys               OrganizationApiKey[]
  ruleSuppressions      OrganizationRuleSuppression[]
  codeSets              OrganizationCodeSet[]
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  @@map("organizations")
}

model OrganizationRuleSuppression {
  id             String       @id(map: "organization_rule_suppressions_pkey") @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_rule_suppressions_organization_id_fkey")
  ruleId         String       @map("rule_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, ruleId], map: "organization_rule_suppressions_organization_id_rule_id_key")
  @@index([organizationId], map: "idx_organization_rule_suppressions_organization_id")
  @@map("organization_rule_suppressions")
}

model Country {
  code      String   @id(map: "countries_pkey")
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("countries")
}

model SystemCodeSet {
  id               String                @id(map: "system_code_sets_pkey")
  airtableRecordId String                @unique(map: "system_code_sets_airtable_record_id_key") @map("airtable_record_id")
  name             String
  description      String                @default("")
  usesHints        Boolean               @default(false) @map("uses_hints")
  isSystem         Boolean               @default(false) @map("is_system")
  codes            SystemCode[]
  organizationSets OrganizationCodeSet[]
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  @@map("system_code_sets")
}

model SystemCode {
  id               String        @id(map: "system_codes_pkey") @default(cuid())
  codeSetId        String        @map("code_set_id")
  codeSet          SystemCodeSet @relation(fields: [codeSetId], references: [id], onDelete: Cascade, map: "system_codes_code_set_id_fkey")
  airtableRecordId String        @unique(map: "system_codes_airtable_record_id_key") @map("airtable_record_id")
  codeId           String        @map("code_id")
  name             String
  description      String        @default("")
  sortOrder        Int           @default(0) @map("sort_order")
  active           Boolean       @default(true)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@unique([codeSetId, codeId], map: "system_codes_code_set_id_code_id_key")
  @@index([codeSetId], map: "idx_system_codes_code_set_id")
  @@map("system_codes")
}

model OrganizationCodeSet {
  id              String             @id(map: "organization_code_sets_pkey") @default(cuid())
  organizationId  String             @map("organization_id")
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_code_sets_organization_id_fkey")
  systemCodeSetId String             @map("system_code_set_id")
  systemCodeSet   SystemCodeSet      @relation(fields: [systemCodeSetId], references: [id], onDelete: Restrict, map: "organization_code_sets_system_code_set_id_fkey")
  name            String
  description     String             @default("")
  codes           OrganizationCode[]
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@unique([organizationId, systemCodeSetId], map: "organization_code_sets_organization_id_system_code_set_id_key")
  @@index([organizationId], map: "idx_organization_code_sets_organization_id")
  @@index([systemCodeSetId], map: "idx_organization_code_sets_system_code_set_id")
  @@map("organization_code_sets")
}

model OrganizationCode {
  id                    String              @id(map: "organization_codes_pkey") @default(cuid())
  organizationCodeSetId String              @map("organization_code_set_id")
  organizationCodeSet   OrganizationCodeSet @relation(fields: [organizationCodeSetId], references: [id], onDelete: Cascade, map: "organization_codes_organization_code_set_id_fkey")
  systemCodeId          String?             @map("system_code_id")
  codeId                String              @map("code_id")
  name                  String
  description           String              @default("")
  descriptionCustomized Boolean             @default(false) @map("description_customized")
  sortOrder             Int                 @default(0) @map("sort_order")
  active                Boolean             @default(true)
  deletedAt             DateTime?           @map("deleted_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  @@unique([organizationCodeSetId, codeId], map: "organization_codes_code_set_id_code_id_key")
  @@index([organizationCodeSetId], map: "idx_organization_codes_organization_code_set_id")
  @@index([systemCodeId], map: "idx_organization_codes_system_code_id")
  @@map("organization_codes")
}

model User {
  id                  String                   @id(map: "users_pkey") @default(cuid())
  googleSubject       String?                  @unique(map: "users_google_subject_key") @map("google_subject")
  email               String                   @unique(map: "users_email_key")
  name                String
  picture             String?
  memberships         OrganizationMembership[]
  sentInvitations     OrganizationInvitation[] @relation("OrganizationInvitationInviter")
  acceptedInvitations OrganizationInvitation[] @relation("OrganizationInvitationAcceptedUser")
  createdApiKeys      OrganizationApiKey[]
  createdAt           DateTime                 @default(now()) @map("created_at")
  updatedAt           DateTime                 @updatedAt @map("updated_at")

  @@map("users")
}

model MagicLinkToken {
  id        String    @id(map: "magic_link_tokens_pkey") @default(cuid())
  email     String
  tokenHash String    @unique(map: "magic_link_tokens_token_hash_key") @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([email], map: "idx_magic_link_tokens_email")
  @@map("magic_link_tokens")
}

model OrganizationMembership {
  id             String       @id(map: "organization_memberships_pkey") @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade, map: "organization_memberships_user_id_fkey")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_memberships_organization_id_fkey")
  role           String
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([userId, organizationId], map: "organization_memberships_user_id_organization_id_key")
  @@index([userId], map: "idx_organization_memberships_user_id")
  @@index([organizationId], map: "idx_organization_memberships_organization_id")
  @@map("organization_memberships")
}

model OrganizationInvitation {
  id               String       @id(map: "organization_invitations_pkey") @default(cuid())
  organizationId   String       @map("organization_id")
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_invitations_organization_id_fkey")
  email            String
  role             String
  tokenHash        String       @unique(map: "organization_invitations_token_hash_key") @map("token_hash")
  invitedByUserId  String       @map("invited_by_user_id")
  invitedByUser    User         @relation("OrganizationInvitationInviter", fields: [invitedByUserId], references: [id], onDelete: Cascade, map: "organization_invitations_invited_by_user_id_fkey")
  acceptedByUserId String?      @map("accepted_by_user_id")
  acceptedByUser   User?        @relation("OrganizationInvitationAcceptedUser", fields: [acceptedByUserId], references: [id], onDelete: SetNull, map: "organization_invitations_accepted_by_user_id_fkey")
  expiresAt        DateTime     @map("expires_at")
  acceptedAt       DateTime?    @map("accepted_at")
  canceledAt       DateTime?    @map("canceled_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@index([organizationId], map: "idx_organization_invitations_organization_id")
  @@index([email], map: "idx_organization_invitations_email")
  @@map("organization_invitations")
}

model OrganizationApiKey {
  id              String       @id(map: "organization_api_keys_pkey") @default(cuid())
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_api_keys_organization_id_fkey")
  name            String
  tokenHash       String       @unique(map: "organization_api_keys_token_hash_key") @map("token_hash")
  keyPrefix       String       @map("key_prefix")
  createdByUserId String       @map("created_by_user_id")
  createdByUser   User         @relation(fields: [createdByUserId], references: [id], onDelete: Cascade, map: "organization_api_keys_created_by_user_id_fkey")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([organizationId], map: "idx_organization_api_keys_organization_id")
  @@map("organization_api_keys")
}

model ServiceProfile {
  id                                     String                    @id(map: "service_profiles_pkey") @default(cuid())
  organizationId                         String                    @map("organization_id")
  organization                           Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "service_profiles_organization_id_fkey")
  serviceProviderUsage                   ServiceProviderUsage[]
  businessActivities                     ServiceBusinessActivity[]
  serviceName                            String?                   @map("service_name")
  serviceDescription                     String?                   @map("service_description")
  serviceUrl                             String?                   @map("service_url")
  userTypes                              Json?                     @map("user_types")
  customerTypes                          Json?                     @map("customer_types")
  availabilityRegions                    Json?                     @map("availability_regions")
  childrenDirected                       Boolean?                  @map("children_directed")
  minimumUserAge                         Int?                      @map("minimum_user_age")
  usesCookiesOrTrackingTechnologies      Boolean?                  @map("uses_cookies_or_tracking_technologies")
  cookieCategories                       Json?                     @map("cookie_categories")
  cookieConsentMechanism                 String?                   @map("cookie_consent_mechanism")
  nonEssentialCookiesBlockedUntilConsent Boolean?                  @map("non_essential_cookies_blocked_until_consent")
  cookieConsentWithdrawalMethod          String?                   @map("cookie_consent_withdrawal_method")
  globalPrivacyControlSupported          Boolean?                  @map("global_privacy_control_supported")
  primaryHostingRegion                   String?                   @map("primary_hosting_region")
  sortOrder                              Int                       @default(0) @map("sort_order")
  createdAt                              DateTime                  @default(now()) @map("created_at")
  updatedAt                              DateTime                  @updatedAt @map("updated_at")

  @@index([organizationId], map: "idx_service_profiles_organization_id")
  @@index([organizationId, sortOrder], map: "idx_service_profiles_organization_id_sort_order")
  @@map("service_profiles")
}

model PrivacyProfile {
  id                           String       @id(map: "privacy_profiles_pkey") @default(cuid())
  organizationId               String       @unique(map: "privacy_profiles_organization_id_key") @map("organization_id")
  organization                 Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "privacy_profiles_organization_id_fkey")
  supportedRights              Json?        @map("supported_rights")
  requestMethods               Json?        @map("request_methods")
  responseTimelineDaysStatus   String?      @map("response_timeline_days_status")
  responseTimelineDays         Int?         @map("response_timeline_days")
  identityVerificationRequired Boolean?     @map("identity_verification_required")
  authorizedAgentSupported     Boolean?     @map("authorized_agent_supported")
  appealProcessExists          Boolean?     @map("appeal_process_exists")
  sendsMarketingEmails         Boolean?     @map("sends_marketing_emails")
  marketingOptOutMethod        String?      @map("marketing_opt_out_method")
  transactionalEmailsSent      Boolean?     @map("transactional_emails_sent")
  crossBorderTransfers         Boolean?     @map("cross_border_transfers")
  transferMechanisms           Json?        @map("transfer_mechanisms")
  sellsOrSharesData            Boolean?     @map("sells_or_shares_data")
  doNotSellLink                String?      @map("do_not_sell_link")
  dpoStatus                    String?      @map("dpo_status")
  dpoName                      String?      @map("dpo_name")
  dpoEmail                     String?      @map("dpo_email")
  euRepresentativeStatus       String?      @map("eu_representative_status")
  euRepresentativeName         String?      @map("eu_representative_name")
  euRepresentativeAddress      String?      @map("eu_representative_address")
  usesAutomatedDecisionMaking  Boolean?     @map("uses_automated_decision_making")
  productionDataInDevelopment  Boolean?     @map("production_data_in_development")
  retentionPolicyExists        Boolean?     @map("retention_policy_exists")
  createdAt                    DateTime     @default(now()) @map("created_at")
  updatedAt                    DateTime     @updatedAt @map("updated_at")

  @@map("privacy_profiles")
}

model InfrastructureProfile {
  id                            String       @id(map: "infrastructure_profiles_pkey") @default(cuid())
  organizationId                String       @unique(map: "infrastructure_profiles_organization_id_key") @map("organization_id")
  organization                  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "infrastructure_profiles_organization_id_fkey")
  mfaEnabled                    Boolean?     @map("mfa_enabled")
  encryptedDevicesRequired      Boolean?     @map("encrypted_devices_required")
  backupsEnabled                Boolean?     @map("backups_enabled")
  centralizedLoggingEnabled     Boolean?     @map("centralized_logging_enabled")
  securityMonitoring            String?      @map("security_monitoring")
  atRestAlgorithm               String?      @map("at_rest_algorithm")
  inTransitMinimumTlsVersion    String?      @map("in_transit_minimum_tls_version")
  keyManagementProvider         String?      @map("key_management_provider")
  backupCadence                 String?      @map("backup_cadence")
  backupRetentionDays           Int?         @map("backup_retention_days")
  backupRetentionDaysStatus     String?      @map("backup_retention_days_status")
  restoreTestingCadence         String?      @map("restore_testing_cadence")
  vendorReviewRequired          Boolean?     @map("vendor_review_required")
  vendorReviewCadence           String?      @map("vendor_review_cadence")
  dpaRequiredForProcessors      Boolean?     @map("dpa_required_for_processors")
  encryptionAtRest              Boolean?     @map("encryption_at_rest")
  encryptionInTransit           Boolean?     @map("encryption_in_transit")
  explicitNoProviderSystemTypes String[]     @default([]) @map("explicit_no_provider_system_types")
  createdAt                     DateTime     @default(now()) @map("created_at")
  updatedAt                     DateTime     @updatedAt @map("updated_at")

  @@map("infrastructure_profiles")
}

model SecurityProfile {
  id                                   String       @id(map: "security_profiles_pkey") @default(cuid())
  organizationId                       String       @unique(map: "security_profiles_organization_id_key") @map("organization_id")
  organization                         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "security_profiles_organization_id_fkey")
  codeReviewRequired                   Boolean?     @map("code_review_required")
  dependencySecurityMonitoring         Boolean?     @map("dependency_security_monitoring")
  secretScanning                       Boolean?     @map("secret_scanning")
  automatedTestingBeforeDeployment     Boolean?     @map("automated_testing_before_deployment")
  cicdDeploymentProcess                Boolean?     @map("cicd_deployment_process")
  productionDeploymentApprovalRequired Boolean?     @map("production_deployment_approval_required")
  scanningCadence                      String?      @map("scanning_cadence")
  penetrationTestingStrategy           String?      @map("penetration_testing_strategy")
  penetrationTestingCadence            String?      @map("penetration_testing_cadence")
  penetrationTestLastDate              String?      @map("penetration_test_last_date")
  patchingSlaCriticalDays              Int?         @map("patching_sla_critical_days")
  patchingSlaCriticalDaysStatus        String?      @map("patching_sla_critical_days_status")
  patchingSlaHighDays                  Int?         @map("patching_sla_high_days")
  patchingSlaHighDaysStatus            String?      @map("patching_sla_high_days_status")
  vulnerabilityDisclosureProgramExists Boolean?     @map("vulnerability_disclosure_program_exists")
  vulnerabilityDisclosureUrl           String?      @map("vulnerability_disclosure_url")
  incidentResponsePlanExists           Boolean?     @map("incident_response_plan_exists")
  incidentNotificationTimeline         String?      @map("incident_notification_timeline")
  customerNotificationProcess          Json?        @map("customer_notification_process")
  incidentResponseLastTestedDate       String?      @map("incident_response_last_tested_date")
  createdAt                            DateTime     @default(now()) @map("created_at")
  updatedAt                            DateTime     @updatedAt @map("updated_at")

  @@map("security_profiles")
}

model OrganizationDataType {
  id                        String                     @id(map: "organization_data_types_pkey") @default(cuid())
  organizationId            String                     @map("organization_id")
  organization              Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "organization_data_types_organization_id_fkey")
  name                      String
  description               String?
  subjectTypes              Json?                      @map("subject_types")
  collectionMethods         Json?                      @map("collection_methods")
  isSensitive               Boolean?                   @map("is_sensitive")
  isRequired                Boolean?                   @map("is_required")
  sortOrder                 Int                        @default(0) @map("sort_order")
  providerUsageDataTypes    ProviderUsageDataType[]
  businessActivityDataTypes BusinessActivityDataType[]
  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")

  @@unique([organizationId, name], map: "organization_data_types_organization_id_name_key")
  @@index([organizationId], map: "idx_organization_data_types_organization_id")
  @@index([organizationId, sortOrder], map: "idx_organization_data_types_organization_id_sort_order")
  @@map("organization_data_types")
}

model BusinessActivity {
  id                            String                     @id(map: "business_activities_pkey") @default(cuid())
  organizationId                String                     @map("organization_id")
  organization                  Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "business_activities_organization_id_fkey")
  name                          String
  purpose                       String                     @default("")
  role                          String                     @default("")
  legalBasis                    String[]                   @default([]) @map("legal_basis")
  retentionPolicy               String?                    @map("retention_policy")
  retentionDays                 Int                        @default(0) @map("retention_days")
  usesAi                        Boolean?                   @map("uses_ai")
  aiUseCases                    String                     @default("") @map("ai_use_cases")
  aiCustomerDataUsedForTraining Boolean?                   @map("ai_customer_data_used_for_training")
  aiCustomerDataSentToProviders Boolean?                   @map("ai_customer_data_sent_to_providers")
  aiHumanReviewOfOutputs        Boolean?                   @map("ai_human_review_of_outputs")
  aiUsersInformedWhenUsed       Boolean?                   @map("ai_users_informed_when_used")
  sortOrder                     Int                        @default(0) @map("sort_order")
  services                      ServiceBusinessActivity[]
  dataTypes                     BusinessActivityDataType[]
  createdAt                     DateTime                   @default(now()) @map("created_at")
  updatedAt                     DateTime                   @updatedAt @map("updated_at")

  @@unique([organizationId, name], map: "business_activities_organization_id_name_key")
  @@index([organizationId], map: "idx_business_activities_organization_id")
  @@index([organizationId, sortOrder], map: "idx_business_activities_organization_id_sort_order")
  @@map("business_activities")
}

model BusinessActivityDataType {
  id                     String               @id(map: "business_activity_data_types_pkey") @default(cuid())
  businessActivityId     String               @map("business_activity_id")
  businessActivity       BusinessActivity     @relation(fields: [businessActivityId], references: [id], onDelete: Cascade, map: "business_activity_data_types_business_activity_id_fkey")
  organizationDataTypeId String               @map("organization_data_type_id")
  organizationDataType   OrganizationDataType @relation(fields: [organizationDataTypeId], references: [id], onDelete: Cascade, map: "business_activity_data_types_organization_data_type_id_fkey")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@unique([businessActivityId, organizationDataTypeId], map: "business_activity_data_types_activity_id_data_type_id_key")
  @@index([businessActivityId], map: "idx_business_activity_data_types_business_activity_id")
  @@index([organizationDataTypeId], map: "idx_business_activity_data_types_organization_data_type_id")
  @@map("business_activity_data_types")
}

model ServiceBusinessActivity {
  id                 String           @id(map: "service_business_activities_pkey") @default(cuid())
  serviceId          String           @map("service_id")
  service            ServiceProfile   @relation(fields: [serviceId], references: [id], onDelete: Cascade, map: "service_business_activities_service_id_fkey")
  businessActivityId String           @map("business_activity_id")
  businessActivity   BusinessActivity @relation(fields: [businessActivityId], references: [id], onDelete: Cascade, map: "service_business_activities_business_activity_id_fkey")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([serviceId, businessActivityId], map: "service_business_activities_service_id_business_activity_id_key")
  @@index([serviceId], map: "idx_service_business_activities_service_id")
  @@index([businessActivityId], map: "idx_service_business_activities_business_activity_id")
  @@map("service_business_activities")
}

model AccessProfile {
  id                                String       @id(map: "access_profiles_pkey") @default(cuid())
  organizationId                    String       @unique(map: "access_profiles_organization_id_key") @map("organization_id")
  organization                      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "access_profiles_organization_id_fkey")
  mfaRequired                       Boolean?     @map("mfa_required")
  ssoEnabled                        Boolean?     @map("sso_enabled")
  sharedAccountsExist               Boolean?     @map("shared_accounts_exist")
  offboardingProcessExists          Boolean?     @map("offboarding_process_exists")
  accessReviewsPerformed            Boolean?     @map("access_reviews_performed")
  leastPrivilege                    Boolean?     @map("least_privilege")
  roleBasedAccess                   Boolean?     @map("role_based_access")
  accessReviewCadence               String?      @map("access_review_cadence")
  adminApprovalRequired             Boolean?     @map("admin_approval_required")
  passwordManagerRequired           Boolean?     @map("password_manager_required")
  securityTrainingRequired          Boolean?     @map("security_training_required")
  confidentialityAgreementsRequired Boolean?     @map("confidentiality_agreements_required")
  createdAt                         DateTime     @default(now()) @map("created_at")
  updatedAt                         DateTime     @updatedAt @map("updated_at")

  @@map("access_profiles")
}

model OrganizationProvider {
  id                    String                 @id(map: "vendors_pkey") @default(cuid())
  organizationId        String                 @map("organization_id")
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "vendors_organization_id_fkey")
  providerId            String?                @map("provider_id")
  systemTypes           String[]               @default([]) @map("system_types")
  name                  String
  legalName             String                 @default("") @map("legal_name")
  category              String
  countryOfRegistration String                 @default("") @map("country_of_registration")
  criticality           String
  notes                 String?
  purpose               String?
  serviceUsage          ServiceProviderUsage[]
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  @@unique([organizationId, name], map: "vendors_organization_id_name_key")
  @@index([organizationId], map: "idx_vendors_organization_id")
  @@index([providerId], map: "idx_vendors_provider_id")
  @@map("organization_providers")
}

model ServiceProviderUsage {
  id                     String                  @id(map: "service_vendor_uses_pkey") @default(cuid())
  organizationId         String                  @map("organization_id")
  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "service_vendor_uses_organization_id_fkey")
  serviceId              String                  @map("service_id")
  service                ServiceProfile          @relation(fields: [serviceId], references: [id], onDelete: Cascade, map: "service_vendor_uses_service_id_fkey")
  organizationProviderId String                  @map("organization_provider_id")
  organizationProvider   OrganizationProvider    @relation(fields: [organizationProviderId], references: [id], onDelete: Cascade, map: "service_vendor_uses_vendor_id_fkey")
  systemType             String?                 @map("system_type")
  purpose                String
  dataProcessingLevel    String                  @default("limited") @map("data_processing_level")
  dpaStatus              String?                 @map("dpa_status")
  dataRegions            String[]                @default([]) @map("data_regions")
  notes                  String?
  dataTypes              ProviderUsageDataType[]
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")

  @@unique([serviceId, organizationProviderId, systemType], map: "service_provider_usage_service_provider_system_key")
  @@index([organizationId], map: "idx_service_vendor_uses_organization_id")
  @@index([serviceId], map: "idx_service_vendor_uses_service_id")
  @@index([organizationProviderId], map: "idx_service_vendor_uses_vendor_id")
  @@index([systemType], map: "idx_service_provider_usage_system_type")
  @@map("service_provider_usage")
}

model Template {
  id                       String       @id(map: "templates_pkey") @default(cuid())
  organizationId           String       @map("organization_id")
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "templates_organization_id_fkey")
  name                     String
  slug                     String
  sourceSystemTemplateSlug String?      @map("source_system_template_slug")
  content                  String
  versionMajor             Int          @default(1) @map("version_major")
  versionMinor             Int          @default(0) @map("version_minor")
  documents                Document[]
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, slug], map: "templates_organization_id_slug_key")
  @@index([organizationId], map: "idx_templates_organization_id")
  @@index([sourceSystemTemplateSlug], map: "idx_templates_source_system_template_slug")
  @@map("templates")
}

model Document {
  id                   String       @id(map: "documents_pkey") @default(cuid())
  organizationId       String       @map("organization_id")
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, map: "documents_organization_id_fkey")
  templateId           String       @map("template_id")
  template             Template     @relation(fields: [templateId], references: [id], onDelete: Cascade, map: "documents_template_id_fkey")
  title                String
  renderedContent      String       @map("rendered_content")
  pdfObjectPath        String?      @map("pdf_object_path")
  sourceHash           String       @map("source_hash")
  sourceFingerprint    Json         @map("source_fingerprint")
  templateVersionMajor Int          @default(1) @map("template_version_major")
  templateVersionMinor Int          @default(0) @map("template_version_minor")
  generatedAt          DateTime     @default(now()) @map("generated_at")

  @@unique([organizationId, templateId, templateVersionMajor, templateVersionMinor], map: "documents_organization_id_template_id_version_key")
  @@index([organizationId], map: "idx_documents_organization_id")
  @@index([templateId], map: "idx_documents_template_id")
  @@map("documents")
}

model ProviderUsageDataType {
  id                     String               @id(map: "vendor_data_types_pkey") @default(cuid())
  serviceProviderUsageId String               @map("service_provider_usage_id")
  serviceProviderUsage   ServiceProviderUsage @relation(fields: [serviceProviderUsageId], references: [id], onDelete: Cascade, map: "vendor_data_types_service_vendor_use_id_fkey")
  organizationDataTypeId String               @map("organization_data_type_id")
  organizationDataType   OrganizationDataType @relation(fields: [organizationDataTypeId], references: [id], onDelete: Cascade, map: "vendor_data_types_organization_data_type_id_fkey")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")

  @@unique([serviceProviderUsageId, organizationDataTypeId], map: "vendor_data_types_use_id_data_type_id_key")
  @@index([serviceProviderUsageId], map: "idx_vendor_data_types_service_vendor_use_id")
  @@index([organizationDataTypeId], map: "idx_vendor_data_types_organization_data_type_id")
  @@map("provider_usage_data_types")
}
