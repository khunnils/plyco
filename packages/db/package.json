{
  "name": "@plyco/db",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "lint": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "echo \"@plyco/db has no test suite yet\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@plyco/shared": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prisma": "7.8.0"
  }
}
